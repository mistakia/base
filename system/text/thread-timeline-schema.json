{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Thread Timeline Entry",
  "description": "Schema for thread timeline entries. Timeline files use JSONL format (timeline.jsonl) where each line is a JSON object conforming to the 'items' schema below.",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["id", "timestamp", "type"],
    "properties": {
      "id": {
        "type": "string",
        "description": "Unique identifier for the timeline entry"
      },
      "timestamp": {
        "type": "string",
        "format": "date-time",
        "description": "When the entry was created (ISO 8601)"
      },
      "type": {
        "type": "string",
        "enum": [
          "message",
          "tool_call",
          "tool_result",
          "thinking",
          "system"
        ],
        "description": "Type of timeline entry (5 primitives)"
      },
      "schema_version": {
        "type": "integer",
        "minimum": 1,
        "description": "Timeline entry schema version. Absent = 1 (legacy 12-type, pre-consolidation). 2 = consolidated 5-type. Producers stamp the current version on write; migrations gate transformations on version, leaving already-current entries untouched."
      },
      "provider": {
        "type": "string",
        "description": "Session provider (claude, cursor, chatgpt, etc.)"
      },
      "provider_data": {
        "type": "object",
        "description": "Provider-specific data and metadata",
        "additionalProperties": true
      },
      "ordering": {
        "type": "object",
        "description": "Timeline ordering and relationship metadata for deterministic sequencing",
        "properties": {
          "sequence": {
            "type": "number",
            "description": "Sequential position in the normalized session (0-based index)"
          },
          "parent_id": {
            "type": ["string", "null"],
            "description": "ID of parent entry for hierarchical relationships"
          }
        },
        "additionalProperties": false
      },
      "role": {
        "description": "Present on message entries; narrowed under allOf[type=message]"
      },
      "content": {
        "description": "Present on message/tool_call/tool_result/thinking/system entries; narrowed under each allOf branch"
      },
      "metadata": {
        "type": "object",
        "description": "Present on most entry types; narrowed under each allOf branch",
        "additionalProperties": true
      },
      "system_type": {
        "description": "Present on system entries; narrowed under allOf[type=system]"
      },
      "thinking_type": {
        "description": "Present on thinking entries; narrowed under allOf[type=thinking]"
      }
    },
    "allOf": [
      {
        "if": {
          "properties": { "type": { "const": "message" } }
        },
        "then": {
          "required": ["role", "content"],
          "properties": {
            "role": {
              "type": "string",
              "enum": ["user", "assistant", "system"],
              "description": "Role of the message sender"
            },
            "content": {
              "oneOf": [
                {
                  "type": "string",
                  "description": "Simple text content"
                },
                {
                  "type": "array",
                  "description": "Structured content blocks",
                  "items": {
                    "type": "object",
                    "properties": {
                      "type": {
                        "type": "string",
                        "enum": [
                          "text",
                          "thinking",
                          "thinking.thinking",
                          "thinking.signature",
                          "tool_use",
                          "tool_result",
                          "image",
                          "code"
                        ]
                      },
                      "content": {
                        "type": "string"
                      },
                      "metadata": {
                        "type": "object",
                        "additionalProperties": true
                      }
                    },
                    "required": ["type", "content"],
                    "additionalProperties": true
                  }
                }
              ],
              "description": "Message content - can be simple text or structured blocks"
            },
            "metadata": {
              "type": "object",
              "description": "Additional message metadata",
              "properties": {
                "model": {
                  "type": "string",
                  "description": "AI model used for this message"
                },
                "request_id": {
                  "type": "string",
                  "description": "Provider request identifier"
                },
                "usage": {
                  "type": "object",
                  "description": "Token usage information",
                  "properties": {
                    "input_tokens": { "type": "number" },
                    "output_tokens": { "type": "number" },
                    "cache_creation_input_tokens": { "type": "number" },
                    "cache_read_input_tokens": { "type": "number" },
                    "service_tier": { "type": "string" }
                  }
                },
                "stop_reason": {
                  "type": ["string", "null"],
                  "description": "Why generation stopped; freeform to accommodate provider-specific values (e.g., 'end_turn', 'stop_sequence', 'tool_use', 'max_tokens', 'refusal', 'pause_turn', null)"
                },
                "stop_sequence": {
                  "type": ["string", "null"]
                },
                "git_branch": {
                  "type": ["string", "null"],
                  "description": "Git branch context"
                },
                "is_meta": {
                  "type": "boolean",
                  "description": "Whether this is a metadata entry"
                },
                "level": {
                  "type": ["string", "number", "null"],
                  "description": "Severity level; client dispatches on string values 'warning'/'error' (see system-event-utils.js). Numeric values are a legacy hierarchical-depth encoding kept for backward compatibility. null appears on entries where the producer had nothing to record."
                },
                "parse_line_number": {
                  "type": "number",
                  "description": "Line number from external session parsing"
                },
                "toolUseID": {
                  "type": ["string", "null"],
                  "description": "Tool use identifier for tracking tool interactions"
                }
              },
              "additionalProperties": true
            }
          }
        }
      },
      {
        "if": {
          "properties": { "type": { "const": "tool_call" } }
        },
        "then": {
          "required": ["content"],
          "properties": {
            "content": {
              "type": "object",
              "required": ["tool_name", "tool_parameters"],
              "properties": {
                "tool_name": {
                  "type": "string",
                  "description": "Name of the tool being called"
                },
                "tool_parameters": {
                  "type": "object",
                  "description": "Parameters passed to the tool",
                  "additionalProperties": true
                },
                "tool_call_id": {
                  "type": "string",
                  "description": "Unique identifier for this tool call"
                },
                "execution_status": {
                  "type": "string",
                  "enum": ["pending", "executing", "completed", "failed"],
                  "description": "Status of tool execution"
                }
              },
              "additionalProperties": false
            }
          }
        }
      },
      {
        "if": {
          "properties": { "type": { "const": "tool_result" } }
        },
        "then": {
          "required": ["content"],
          "properties": {
            "content": {
              "type": "object",
              "required": ["tool_call_id"],
              "properties": {
                "tool_call_id": {
                  "type": "string",
                  "description": "ID of the corresponding tool call"
                },
                "result": {
                  "description": "Result data from the tool execution",
                  "oneOf": [
                    { "type": "object" },
                    { "type": "array" },
                    { "type": "string" },
                    { "type": "number" },
                    { "type": "boolean" },
                    { "type": "null" }
                  ]
                },
                "error": {
                  "type": ["object", "string", "null"],
                  "description": "Error information if tool execution failed. In practice emitted as a string by all upstream tool providers; object form is reserved for structured error details with message/code/details."
                }
              },
              "additionalProperties": false
            }
          }
        }
      },
      {
        "if": {
          "properties": { "type": { "const": "system" } }
        },
        "then": {
          "required": ["content"],
          "properties": {
            "content": {
              "type": "string",
              "description": "Human-readable system message content. Structured data belongs in metadata."
            },
            "system_type": {
              "type": "string",
              "enum": [
                "status",
                "state_change",
                "error",
                "configuration",
                "compaction",
                "branch_point"
              ],
              "description": "Discriminator for system event kind. status: general informational updates. state_change: execution/thread lifecycle transitions (metadata.thread_lifecycle=true for thread state). error: error events (message in content, error_type in metadata). configuration: model/thinking_level/setting changes. compaction: context compression events. branch_point: conversation fork annotations."
            },
            "metadata": {
              "type": "object",
              "description": "System-specific metadata. Contract by system_type: state_change requires from_state/to_state; error requires error_type; others have optional fields (see plan).",
              "additionalProperties": true
            }
          },
          "allOf": [
            {
              "if": {
                "properties": {
                  "system_type": { "const": "state_change" }
                },
                "required": ["system_type"]
              },
              "then": {
                "required": ["metadata"],
                "properties": {
                  "metadata": {
                    "type": "object",
                    "required": ["from_state", "to_state"],
                    "properties": {
                      "from_state": { "type": "string" },
                      "to_state": { "type": "string" }
                    }
                  }
                }
              }
            },
            {
              "if": {
                "properties": {
                  "system_type": { "const": "error" }
                },
                "required": ["system_type"]
              },
              "then": {
                "required": ["metadata"],
                "properties": {
                  "metadata": {
                    "type": "object",
                    "required": ["error_type"],
                    "properties": {
                      "error_type": { "type": "string" }
                    }
                  }
                }
              }
            }
          ]
        }
      },
      {
        "if": {
          "properties": { "type": { "const": "thinking" } }
        },
        "then": {
          "required": ["content"],
          "properties": {
            "content": {
              "oneOf": [
                {
                  "type": "string",
                  "description": "Simple thinking content"
                },
                {
                  "type": "object",
                  "description": "Structured thinking content",
                  "properties": {
                    "thinking": {
                      "type": "string",
                      "description": "Main thinking content"
                    },
                    "signature": {
                      "type": "string",
                      "description": "Thinking signature or metadata"
                    }
                  },
                  "additionalProperties": true
                }
              ],
              "description": "AI model's internal reasoning content"
            },
            "thinking_type": {
              "type": "string",
              "description": "Type of thinking process (freeform label; real producers currently only emit 'reasoning' — broaden if you plumb real values from sources)"
            },
            "metadata": {
              "type": "object",
              "description": "Thinking-specific metadata",
              "additionalProperties": true
            }
          }
        }
      }
    ],
    "additionalProperties": false
  }
}
