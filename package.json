  "scripts": {
    "dev": "concurrently \"yarn start\" \"yarn start:api\"",
    "start": "node cli/dev-server.mjs",
    "start:api": "NODE_OPTIONS='--max-old-space-size=8192' nodemon services/server.mjs",
    "lint": "eslint . --ext js,mjs --ignore-pattern build",
    "prettier": "prettier --write .",
    "find-large-files": "node cli/find-large-files.mjs",
    "test": "CONFIG_ENCRYPTION_KEY=ca25b9c4f1c26bc9a6475af467d9885d3b2a9d9a98a815a15af1264e6c50444a NODE_ENV=test TEST=all mocha --exit",
    "test:all": "CONFIG_ENCRYPTION_KEY=ca25b9c4f1c26bc9a6475af467d9885d3b2a9d9a98a815a15af1264e6c50444a NODE_ENV=test TEST=all mocha --exit --ignore './tests/unit/embedded-database-index/**/*.mjs' --ignore './tests/integration/embedded-database-index/**/*.mjs' --ignore './tests/integration/file/mcp-tools.test.mjs' ./tests/unit/**/*.mjs ./tests/integration/**/*.mjs && yarn test:embedded-db && yarn test:mcp",
    "test:embedded-db": "CONFIG_ENCRYPTION_KEY=ca25b9c4f1c26bc9a6475af467d9885d3b2a9d9a98a815a15af1264e6c50444a NODE_ENV=test mocha --exit ./tests/unit/embedded-database-index/**/*.mjs ./tests/integration/embedded-database-index/**/*.mjs",
    "test:mcp": "CONFIG_ENCRYPTION_KEY=ca25b9c4f1c26bc9a6475af467d9885d3b2a9d9a98a815a15af1264e6c50444a NODE_ENV=test mocha --exit --timeout 30000 ./tests/integration/file/mcp-tools.test.mjs",
    "test:unit": "CONFIG_ENCRYPTION_KEY=ca25b9c4f1c26bc9a6475af467d9885d3b2a9d9a98a815a15af1264e6c50444a NODE_ENV=test mocha --exit ./tests/unit/**/*.mjs",
    "test:integration": "CONFIG_ENCRYPTION_KEY=ca25b9c4f1c26bc9a6475af467d9885d3b2a9d9a98a815a15af1264e6c50444a NODE_ENV=test mocha --exit ./tests/integration/**/*.mjs",
    "test:markdown": "DEBUG=markdown CONFIG_ENCRYPTION_KEY=ca25b9c4f1c26bc9a6475af467d9885d3b2a9d9a98a815a15af1264e6c50444a NODE_ENV=test mocha --exit ./tests/unit/markdown/**/*.mjs",
    "test:git": "DEBUG='mcp:*,git' CONFIG_ENCRYPTION_KEY=ca25b9c4f1c26bc9a6475af467d9885d3b2a9d9a98a815a15af1264e6c50444a NODE_ENV=test mocha --exit ./tests/unit/git/**/*.mjs ./tests/integration/git/**/*.mjs",
    "test:api": "DEBUG='api:*' CONFIG_ENCRYPTION_KEY=ca25b9c4f1c26bc9a6475af467d9885d3b2a9d9a98a815a15af1264e6c50444a NODE_ENV=test mocha --exit ./tests/integration/api/**/*.mjs",
    "test:sync": "DEBUG='sync:*' CONFIG_ENCRYPTION_KEY=ca25b9c4f1c26bc9a6475af467d9885d3b2a9d9a98a815a15af1264e6c50444a NODE_ENV=test mocha --exit ./tests/integration/sync/**/*.mjs ./tests/unit/sync/**/*.mjs",
    "test:threads": "DEBUG='threads:*' CONFIG_ENCRYPTION_KEY=ca25b9c4f1c26bc9a6475af467d9885d3b2a9d9a98a815a15af1264e6c50444a NODE_ENV=test mocha --exit ./tests/integration/threads/**/*.mjs",
    "test:file": "CONFIG_ENCRYPTION_KEY=ca25b9c4f1c26bc9a6475af467d9885d3b2a9d9a98a815a15af1264e6c50444a NODE_ENV=test mocha --exit",
    "build": "webpack --mode production --config webpack/webpack.prod.babel.mjs",
    "deploy": "pm2 deploy server.pm2.config.js production --force",
    "deploy:setup": "pm2 deploy server.pm2.config.js production setup",
    "deploy:dist": "rsync -av --exclude 'stats.html' --include 'bundle-manifest.json' build/ storage:/home/user/base/source/build",
    "sync:config": "./cli/sync-config.sh",
    "sync:config:dry": "./cli/sync-config.sh --dry-run",
    "sync:config:all": "./cli/sync-config.sh --all",
    "rebuild:index": "DEBUG='cli:rebuild-index,embedded-index*' node cli/rebuild-embedded-index.mjs"
  },
