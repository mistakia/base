{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@views/*": ["./client/views/*"],
      "@pages/*": ["./client/views/pages/*"],
      "@core/*": ["./client/core/*"],
      "@components/*": ["./client/views/components/*"],
      "@styles/*": ["./client/styles/*"],
      "@config": ["./config.mjs"],
      "@libs-shared/*": ["./libs-shared/*"],
      "@theme/*": ["./client/theme/*"],
      "#root/*": ["./*"],
      "#server": ["./server/index.mjs"],
      "#server/*": ["./server/*"],
      "#config": ["./config/index.mjs"],
      "#config/*": ["./config/*"],
      "#libs-server": ["./libs-server/index.mjs"],
      "#libs-server/*": ["./libs-server/*"],
      "#libs-shared": ["./libs-shared/index.mjs"],
      "#libs-shared/*": ["./libs-shared/*"],
      "#tests/*": ["./tests/*"],
      "#cli/*": ["./cli/*"],
      "#services/*": ["./services/*"]
    }
  },
  "include": [
    "client/**/*",
    "server/**/*",
    "libs-server/**/*",
    "libs-shared/**/*",
    "services/**/*",
    "config/**/*",
    "cli/**/*",
    "tests/**/*"
  ],
  "exclude": ["node_modules", "build", "tmp"]
}
