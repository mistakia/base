// =====================================================
// GLOBAL UTILITIES & COMPOSABLE CLASSES
// =====================================================

// Pulse animation for active/live indicators
@keyframes pulse
  0%
    opacity: 1
  50%
    opacity: 0.4
  100%
    opacity: 1

// =====================================================
// TWO COLUMN LAYOUT SYSTEM
// =====================================================

.two-column-container
  display: flex
  flex-direction: column
  gap: var(--space-base)
  
  @media (min-width: 992px) // lg breakpoint
    flex-direction: row
    gap: var(--space-lg)

.two-column-left
  flex: 1
  min-width: 0 // Prevent flex item overflow
  
  @media (min-width: 992px) // lg breakpoint
    flex: 2 // Default to 8/12 ratio (2:1)

.two-column-right
  flex: 1
  min-width: 0 // Prevent flex item overflow
  max-width: 100% // Ensure children don't exceed parent
  overflow: hidden // Clip any overflowing content
  padding-bottom: $space_base
  order: -1 // Show metadata above content on mobile

  // Ensure all direct children respect parent width constraints
  > *
    width: 100%
    max-width: 100%
    min-width: 0
    overflow: hidden

  @media (min-width: 992px) // lg breakpoint
    flex: 1 // Default to 4/12 ratio (1:2 with left)
    order: 0 // Reset to DOM order on desktop

// Sticky right column variant
.two-column-right-sticky
  @media (min-width: 992px) // lg breakpoint
    position: sticky
    top: 20px
    height: fit-content

// Sticky left column variant
.two-column-left-sticky
  @media (min-width: 992px) // lg breakpoint
    position: sticky
    top: 20px
    height: fit-content

// Custom width variants
.two-column-left-wide
  @media (min-width: 992px)
    flex: 3 // 9/12 ratio

.two-column-right-narrow  
  @media (min-width: 992px)
    flex: 1 // 3/12 ratio

.two-column-left-narrow
  @media (min-width: 992px)
    flex: 1 // 3/12 ratio

.two-column-right-wide
  @media (min-width: 992px)
    flex: 3 // 9/12 ratio

// Equal columns
.two-column-equal
  .two-column-left,
  .two-column-right
    @media (min-width: 992px)
      flex: 1

