// =====================================================
// EXPANDED VIEWS
// =====================================================

.tag-expanded
  min-height: 400px

.tag-expanded__header
  display: flex
  justify-content: space-between
  align-items: center
  margin-bottom: 20px
  padding-bottom: 16px
  border-bottom: 1px solid $color_border

.tag-expanded__title
  margin: 0
  font-size: $font_size_lg
  font-weight: 600
  color: $color_text_primary

.tag-expanded__close
  display: flex
  align-items: center
  justify-content: center
  width: 32px
  height: 32px
  border: none
  background: transparent
  color: $color_text_secondary
  cursor: pointer
  border-radius: $radius_sm
  transition: background $transition_fast

  &:hover
    background: rgba(0, 0, 0, 0.05)

.tag-expanded__list
  margin: 0
  padding: 0
  list-style: none

.tag-expanded__item
  margin-bottom: 8px

.tag-expanded__link
  display: flex
  flex-direction: column
  padding: 12px 16px
  background: rgba(0, 0, 0, 0.02)
  border-radius: $radius_md
  text-decoration: none
  transition: background $transition_fast

  &:hover
    background: rgba(0, 0, 0, 0.04)

.tag-expanded__item-main
  display: flex
  flex-direction: column
  gap: 4px
  margin-bottom: 8px

.tag-expanded__item-title
  font-size: $font_size_sm
  font-weight: 500
  color: $color_text_primary

.tag-expanded__item-description
  font-size: $font_size_xs
  color: $color_text_secondary
  white-space: nowrap
  overflow: hidden
  text-overflow: ellipsis

.tag-expanded__item-meta
  display: flex
  align-items: center
  gap: 8px

.tag-expanded__status,
.tag-expanded__state
  font-size: $font_size_xs
  padding: 2px 6px
  border-radius: $radius_sm

.tag-expanded__priority
  font-size: $font_size_xs
  padding: 2px 6px
  border-radius: $radius_sm

.tag-expanded__count,
.tag-expanded__time
  font-size: $font_size_xs
  color: $color_text_secondary

.tag-expanded__entity-groups
  display: flex
  flex-direction: column
  gap: 24px

.tag-expanded__type-group
  display: flex
  flex-direction: column

.tag-expanded__type-heading
  display: flex
  align-items: center
  gap: 8px
  margin: 0 0 12px 0
  font-size: $font_size_sm
  font-weight: 600

.tag-expanded__type-label
  font-size: $font_size_xs
  padding: 2px 6px
  border-radius: $radius_sm
  white-space: nowrap
  font-weight: 500

.tag-expanded__type-count
  font-size: $font_size_xs
  color: $color_text_secondary

