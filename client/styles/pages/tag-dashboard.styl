// =====================================================
// TAG DASHBOARD STYLES
// =====================================================
// Styles for the tag detail page dashboard showing
// related tasks, threads, and distribution graphs.

@import '../tasks'

// =====================================================
// MAIN CONTAINER
// =====================================================

.tag-dashboard
  margin-top: 24px
  background: $color_background

  &--loading,
  &--error
    display: flex
    align-items: center
    justify-content: center
    min-height: 200px

  &__loading-text,
  &__error-text
    color: $color_text_secondary
    font-size: $font_size_sm

  &__error-text
    color: $color_error

// =====================================================
// HEADER
// =====================================================

.tag-dashboard__header
  display: flex
  justify-content: space-between
  align-items: center
  margin-bottom: 20px
  padding-bottom: 16px
  border-bottom: 1px solid $color_border

.tag-dashboard__counts
  display: flex
  align-items: center
  gap: 12px
  font-size: $font_size_sm
  color: $color_text_secondary

.tag-dashboard__count-separator
  color: $color_border

// =====================================================
// PANELS GRID
// =====================================================

.tag-dashboard__panels
  display: grid
  grid-template-columns: repeat(2, 1fr)
  gap: 20px
  margin-bottom: 20px
  overflow-x: auto
  min-width: 0

  &[data-panel-count="3"]
    grid-template-columns: repeat(3, 1fr)

    @media (max-width: 1024px)
      grid-template-columns: repeat(2, 1fr)

  @media (max-width: 768px)
    grid-template-columns: 1fr

// =====================================================
// TASKS PANEL
// =====================================================

.tag-tasks-panel
  padding: 16px
  background: rgba(0, 0, 0, 0.02)
  border-radius: $radius_md
  min-width: 0

.tag-tasks-panel__header
  display: flex
  justify-content: space-between
  align-items: center
  margin-bottom: 12px

.tag-tasks-panel__title
  margin: 0
  font-size: $font_size_sm
  font-weight: 600
  color: $color_text_primary

.tag-tasks-panel__count
  font-size: $font_size_xs
  color: $color_text_secondary
  background: $color_background
  padding: 2px 8px
  border-radius: $radius_sm

.tag-tasks-panel__empty
  color: $color_text_secondary
  font-size: $font_size_sm
  text-align: center
  padding: 20px

.tag-tasks-panel__list
  margin: 0
  padding: 0
  list-style: none

.tag-tasks-panel__item
  margin-bottom: 8px

  &:last-child
    margin-bottom: 0

.tag-tasks-panel__link
  display: flex
  align-items: center
  gap: 8px
  padding: 8px 12px
  background: $color_background
  border-radius: $radius_sm
  text-decoration: none
  transition: background $transition_fast

  &:hover
    background: rgba(0, 0, 0, 0.03)

.tag-tasks-panel__task-title
  flex: 1
  font-size: $font_size_sm
  color: $color_text_primary
  white-space: nowrap
  overflow: hidden
  text-overflow: ellipsis

.tag-tasks-panel__status
  font-size: $font_size_xs
  padding: 2px 6px
  border-radius: $radius_sm
  white-space: nowrap

.tag-tasks-panel__priority
  font-size: $font_size_xs
  padding: 2px 6px
  border-radius: $radius_sm
  white-space: nowrap

// Apply canonical status colors via data attributes
.tag-tasks-panel__status,
.tag-expanded__status
  for status_name in completed in_progress started blocked abandoned planned paused waiting
    &[data-status={'"' + status_name + '"'}]
      color: $task_status_colors[status_name]
      background: rgba($task_status_colors[status_name], 0.15)
  &[data-status="no_status"],
  &:not([data-status])
    color: $task_status_colors[no_status]
    background: rgba($task_status_colors[no_status], 0.15)

// Apply canonical priority colors via data attributes
.tag-tasks-panel__priority,
.tag-expanded__priority
  for priority_name in critical high medium low
    &[data-priority={'"' + priority_name + '"'}]
      color: $task_priority_colors[priority_name]
      background: rgba($task_priority_colors[priority_name], 0.15)
  &[data-priority="none"],
  &:not([data-priority])
    color: $task_priority_colors[none]
    background: rgba($task_priority_colors[none], 0.15)

.tag-tasks-panel__footer
  margin-top: 12px
  padding-top: 12px
  border-top: 1px solid $color_border
  text-align: center

.tag-tasks-panel__view-all
  display: inline-flex
  align-items: center
  gap: 4px
  font-size: $font_size_xs
  color: $color_primary
  text-decoration: none

  &:hover
    text-decoration: underline

