// Global scroll behavior to avoid rubberbanding and duplicate scrollbars
html, body, #app
  height: 100%
  overscroll-behavior: none
  overscroll-behavior-y: none

body
  overflow: hidden
  -webkit-overflow-scrolling: auto

  &::after
    content: "";
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-image: linear-gradient(rgba(150, 150, 147, 0.1) 1px, transparent 1px);
    background-size: 2px 2px;
    background-repeat: repeat;
    pointer-events: none;
    z-index: 9999;

// Layout wrapper - scrolls both horizontally and vertically
.page-layout
  position: relative
  height: 100vh
  overflow: auto
  overscroll-behavior: none
  padding: 0 var(--space-base) 30px
  max-width: 100%

// Header area - scrolls away vertically, stays in place horizontally
.page-header-area
  position: sticky
  left: 0
  width: 100%
  max-width: 100vw
  padding-top: 20px
  background: $color_surface
  z-index: 10

// Main page content container with width constraints
.page-content-container
  box-sizing: border-box
  padding-bottom: 100px
  padding-top: 32px

// Sessions panel shown below header on non-homepage pages
.page-sessions-panel
  padding: var(--space-sm) var(--space-base) 12px
  margin: var(--space-base) auto 0
  max-width: 1200px
  background: rgba(0, 0, 0, 0.02)
  border-bottom: 1px solid var(--color-border-light)
  overflow: visible

// Homepage specific sections
.homepage-section
  margin-bottom: var(--space-2xl)

  &:last-child
    margin-bottom: 0

.threads-grid
  display: grid
  grid-template-columns: repeat(auto-fill, minmax(400px, 1fr))
  gap: var(--space-xs)
  padding: 0
  margin: 0

.all-threads-link
  color: var(--color-text-secondary)
  text-decoration: none
  font-size: var(--font-size-sm)
  margin-top: var(--space-base)
  display: inline-block
  
  &:hover
    color: var(--color-text)
    text-decoration: underline

.thread-item
  padding: var(--space-base)
  border-bottom: 1px solid var(--color-border-light)
  transition: background-color 0.15s ease
  cursor: pointer

  &:hover
    background-color: var(--color-surface-hover)

  &:last-child
    border-bottom: none

.thread-item-title
  font-size: var(--font-size-base)
  font-weight: 500
  color: var(--color-text)
  margin-bottom: var(--space-xs)

.thread-item-meta
  font-size: var(--font-size-sm)
  color: var(--color-text-secondary)

// Global bottom bar for breadcrumbs and input
.bottom-bar
  position: fixed
  left: 0
  right: 0
  bottom: 0
  background: var(--color-bg, #ffffff)
  border-top: 1px solid var(--color-border, #e1e4e8)
  padding: 0
  z-index: 100
  display: flex
  flex-direction: column-reverse
  font-family: var(--font-family-mono)
  font-size: var(--font-size-sm)
  color: var(--color-text)
  overflow: visible

  // Refine MUI breadcrumbs inside the bar to match mono/compact Emacs feel
  .MuiBreadcrumbs-root
    font-family: inherit
    font-size: inherit

  .MuiBreadcrumbs-separator
    color: var(--color-text-tertiary)
    margin: 0 var(--space-xs)

  .MuiLink-root
    color: var(--color-text)
    text-decoration: none

    &:hover
      text-decoration: underline


// Generic loading state used on pages
.loading-state
  display flex
  align-items center
  justify-content center
  height 100%
  color var(--color-text-secondary)
  padding 2rem
  text-align center
  background-color #f5f5f5
  border-radius var(--radius-base)