// Global scroll behavior to avoid rubberbanding and duplicate scrollbars
html, body, #app
  height: 100%
  overscroll-behavior: none
  overscroll-behavior-y: none

body
  overflow: hidden
  -webkit-overflow-scrolling: auto

  &::after
    content: "";
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-image: linear-gradient(rgba(150, 150, 147, 0.1) 1px, transparent 1px);
    background-size: 2px 2px;
    background-repeat: repeat;
    pointer-events: none;
    z-index: 9999;

// Main page content container with width constraints
.page-content-container
  box-sizing: border-box
  padding-bottom: 100px
  padding-top: 32px

// Layout wrapper to ensure bottom bar overlays while content scrolls underneath
.page-layout
  position: relative
  height: 100vh
  overflow: auto
  overscroll-behavior: none
  overscroll-behavior-y: none
  padding: 20px $space_base 30px
  max-width: 100%

// Homepage specific sections
.homepage-section
  margin-bottom: $space_2xl

  &:last-child
    margin-bottom: 0

.threads-grid
  display: grid
  grid-template-columns: repeat(auto-fill, minmax(400px, 1fr))
  gap: $space_xs
  padding: 0
  margin: 0

.all-threads-link
  color: $color_text_secondary
  text-decoration: none
  font-size: $font_size_sm
  margin-top: $space_base
  display: inline-block
  
  &:hover
    color: $color_text
    text-decoration: underline

.thread-item
  padding: $space_base
  border-bottom: 1px solid $color_border_light
  transition: background-color $transition_fast
  cursor: pointer

  &:hover
    background-color: $color_surface_hover

  &:last-child
    border-bottom: none

.thread-item-title
  font-size: $font_size_base
  font-weight: $font_weight_medium
  color: $color_text
  margin-bottom: $space_xs

.thread-item-meta
  font-size: $font_size_sm
  color: $color_text_secondary

// Global bottom bar for breadcrumbs and input
.bottom-bar
  position: fixed
  left: 0
  right: 0
  bottom: 0
  background: var(--color-bg, #ffffff)
  border-top: 1px solid var(--color-border, #e1e4e8)
  padding: 0
  z-index: 100
  display: flex
  flex-direction: column-reverse
  font-family: $font_family_mono
  font-size: $font_size_sm
  color: $color_text
  overflow: visible

  // Refine MUI breadcrumbs inside the bar to match mono/compact Emacs feel
  .MuiBreadcrumbs-root
    font-family: inherit
    font-size: inherit

  .MuiBreadcrumbs-separator
    color: $color_text_tertiary
    margin: 0 $space_xs

  .MuiLink-root
    color: $color_text
    text-decoration: none

    &:hover
      text-decoration: underline


// Generic loading state used on pages
.loading-state
  display flex
  align-items center
  justify-content center
  height 100%
  color $color_text_secondary
  padding 2rem
  text-align center
  background-color #f5f5f5
  border-radius $radius_base