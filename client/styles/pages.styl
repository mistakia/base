// Global scroll behavior to avoid rubberbanding and duplicate scrollbars
html, body, #app
  height: 100%
  overscroll-behavior: none
  overscroll-behavior-y: none

body
  overflow: hidden
  -webkit-overflow-scrolling: auto

// Main page content container with width constraints
.page-content-container
  box-sizing: border-box
  padding-bottom: 100px
  padding-top: 32px

// Layout wrapper to ensure bottom bar overlays while content scrolls underneath
.page-layout
  position: relative
  height: 100vh
  overflow: auto
  overscroll-behavior: none
  overscroll-behavior-y: none

  // Responsive adjustments
  @media (max-width: 768px)
    padding: $space_base
    max-width: 100%

// Homepage specific sections
.homepage-section
  margin-bottom: $space_2xl

  &:last-child
    margin-bottom: 0

.threads-grid
  display: grid
  grid-template-columns: repeat(auto-fill, minmax(400px, 1fr))
  gap: $space_xs
  padding: 0
  margin: 0

.all-threads-link
  color: $color_text_secondary
  text-decoration: none
  font-size: $font_size_sm
  margin-top: $space_base
  display: inline-block
  
  &:hover
    color: $color_text
    text-decoration: underline

.thread-item
  padding: $space_base
  border-bottom: 1px solid $color_border_light
  transition: background-color $transition_fast
  cursor: pointer

  &:hover
    background-color: $color_surface_hover

  &:last-child
    border-bottom: none

.thread-item-title
  font-size: $font_size_base
  font-weight: $font_weight_medium
  color: $color_text
  margin-bottom: $space_xs

.thread-item-meta
  font-size: $font_size_sm
  color: $color_text_secondary

// Global bottom bar for breadcrumbs
.bottom-bar
  position: fixed
  left: 0
  right: 0
  bottom: 0
  background: transparent
  border-top: none
  padding: 0
  height: 30px
  z-index: 100
  display: flex
  align-items: stretch
  font-family: $font_family_mono
  font-size: $font_size_sm
  color: $color_text
  overflow: hidden

  // Refine MUI breadcrumbs inside the bar to match mono/compact Emacs feel
  .MuiBreadcrumbs-root
    font-family: inherit
    font-size: inherit

  .MuiBreadcrumbs-separator
    color: $color_text_tertiary
    margin: 0 $space_xs

  .MuiLink-root
    color: $color_text
    text-decoration: none

    &:hover
      text-decoration: underline


// Generic loading state used on pages
.loading-state
  display flex
  align-items center
  justify-content center
  height 100%
  color $color_text_secondary
  padding 2rem
  text-align center
  background-color #f5f5f5
  border-radius $radius_base

// Directory markdown viewer container
.directory-markdown-container
  max-width 1100px
  margin 0 auto
  margin-bottom: $space_xl
  padding: $space_lg
  background-color: rgba($color_surface, 0.5)
  border: 1px solid $color_border_light
  border-radius: $radius_base
  
  // Responsive adjustments
  @media (max-width: 768px)
    margin-bottom: $space_lg
    padding: $space_base