// Global scroll behavior to avoid rubberbanding and duplicate scrollbars
html, body, #app
  height: 100%
  overscroll-behavior: none
  overscroll-behavior-y: none

// iOS Status Bar background color - matches breadcrumb bar background
// When using black-translucent, the status bar shows the page background behind it
html
  background-color: var(--color-breadcrumb-bar-bg)
  // Create a status bar background that matches breadcrumb bar background
  &::before
    content: ""
    position: fixed
    top: 0
    left: 0
    right: 0
    height: env(safe-area-inset-top, 0px)
    background-color: var(--color-breadcrumb-bar-bg)
    z-index: 10000
    pointer-events: none

body
  overflow: hidden
  -webkit-overflow-scrolling: auto
  background-color: var(--color-surface)

  &::after
    content: "";
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-image: linear-gradient(rgba(150, 150, 147, 0.1) 1px, transparent 1px);
    background-size: 2px 2px;
    background-repeat: repeat;
    pointer-events: none;
    z-index: 9999;

// Layout wrapper - scrolls both horizontally and vertically
.page-layout
  position: relative
  height: 100vh
  overflow: auto
  overscroll-behavior: none
  padding: 0 var(--space-base) 30px
  max-width: 100%

  // On mobile, add top padding for breadcrumb bar at top
  @media (max-width: 768px)
    padding: 30px var(--space-base) 0

// Header area - scrolls away vertically, stays in place horizontally
.page-header-area
  position: sticky
  left: 0
  width: 100%
  max-width: 100%
  padding-top: 20px
  background: $color_surface
  z-index: 10

// Main page content container with width constraints
.page-content-container
  box-sizing: border-box
  padding-bottom: 100px
  padding-top: 32px

  // On mobile, adjust padding for breadcrumb at top and clear fixed input trigger at bottom
  @media (max-width: 768px)
    padding-top: 12px
    padding-bottom: 140px

// Sessions panel shown below header on non-homepage pages
.page-sessions-panel
  padding: var(--space-sm) var(--space-base) 12px
  margin: var(--space-base) auto 0
  max-width: 1200px
  background: rgba(0, 0, 0, 0.02)
  border: 1px solid var(--color-border-light)
  overflow: visible
  min-height: 59px

  // On mobile, make full width with no horizontal padding
  @media (max-width: 768px)
    margin-left: calc(-1 * var(--space-base))
    margin-right: calc(-1 * var(--space-base))
    padding-left: 0
    padding-right: 0
    border-left: none
    border-right: none
    max-width: none
    width: calc(100% + 2 * var(--space-base))

.all-threads-link
  color: var(--color-text-secondary)
  text-decoration: none
  font-size: var(--font-size-sm)
  margin-top: var(--space-base)
  display: inline-block

  &:hover
    color: var(--color-text)
    text-decoration: underline

// Global bottom bar for breadcrumbs and input
.bottom-bar
  position: fixed
  left: 0
  right: 0
  bottom: 0
  background: var(--color-bg, #ffffff)
  border-top: 1px solid var(--color-border, #e1e4e8)
  padding: 0
  z-index: 100
  display: flex
  flex-direction: column-reverse
  font-family: var(--font-family-mono)
  font-size: var(--font-size-sm)
  color: var(--color-text)
  overflow: visible

  // On mobile, move to top instead of bottom
  @media (max-width: 768px)
    top: 0
    bottom: auto
    border-top: none
    border-bottom: 1px solid var(--color-border, #e1e4e8)

  // Refine MUI breadcrumbs inside the bar to match mono/compact Emacs feel
  .MuiBreadcrumbs-root
    font-family: inherit
    font-size: inherit

  .MuiBreadcrumbs-separator
    color: var(--color-text-tertiary)
    margin: 0 var(--space-xs)

  .MuiLink-root
    color: var(--color-text)
    text-decoration: none

    &:hover
      text-decoration: underline


// Generic loading state used on pages
.loading-state
  display flex
  align-items center
  justify-content center
  height 100%
  color var(--color-text-secondary)
  padding 2rem
  text-align center
  background-color var(--color-surface-secondary)
  border-radius var(--radius-base)