// =====================================================
// MINIMALIST INDUSTRIAL DESIGN SYSTEM
// =====================================================

// Typography Scale
$font_family_mono = 'Monaco', 'Menlo', 'Ubuntu Mono', monospace
$font_size_xs = 11px
$font_size_sm = 12px
$font_size_base = 14px
$font_size_lg = 16px
$font_size_xl = 18px
$font_size_2xl = 20px
$font_size_3xl = 24px
$font_weight_normal = 400
$font_weight_medium = 500
$font_weight_semibold = 600
$font_weight_bold = 700

// Spacing Scale (Modular 8px grid)
$space_xs = 4px
$space_sm = 8px
$space_base = 16px
$space_lg = 24px
$space_xl = 32px
$space_2xl = 48px
$space_3xl = 64px

// Border Radius Scale (Minimal)
$radius_none = 0
$radius_sm = 2px
$radius_base = 4px

// Shadow Scale (Subtle)
$shadow_sm = 0 4px 12px rgba(0, 0, 0, 0.05)

// =====================================================
// COLOR SYSTEM (Single Source of Truth)
// =====================================================

// Neutral Colors
$color_text = #212529
$color_text_secondary = #6c757d
$color_text_tertiary = #b0b0b0
$color_border = #ced4da
$color_border_light = #e9ecef
$color_surface = #ffffff
$color_surface_hover = #fafafa
$color_surface_secondary = #f8f9fa

// Action Colors
$color_primary = #007bff
$color_primary_hover = #0069d9
$color_primary_disabled = #83b9f3
$color_link = #007bff

// Status Colors
$color_success = #28a745
$color_success_subtle = #d4edda
$color_warning = #ffc107
$color_warning_subtle = #fff3cd
$color_danger = #dc3545
$color_danger_subtle = #f8d7da

// Code/Technical Colors
$color_code_bg = #f6f8fa
$color_code_border = #e1e4e8

// =====================================================
// COMPONENT TOKENS
// =====================================================

// Grid System
$grid_gap = 1px
$grid_min_column = 280px

// Interactive States
$transition_fast = 0.15s ease
$transition_base = 0.2s ease
$hover_lift = translateY(-1px)

// Form Controls
$input_padding_y = 12px
$input_padding_x = 16px
$input_border_width = 1px

// RGB values for alpha operations
$primary_color_rgb = 0, 123, 255
