@import './variables'

// =====================================================
// MINIMALIST INDUSTRIAL MIXINS
// =====================================================

// Form input dimensions
$input_padding_y = 12px
$input_padding_x = 16px
$input_border_width = 1px

// Form Control Pattern
form-control()
  font-family $font_family_mono
  font-size $font_size_base
  padding $input_padding_y $input_padding_x
  border $input_border_width solid $color_border
  border-radius $radius_base
  background $color_surface
  color $color_text
  transition border-color $transition_base, box-shadow $transition_base

  &:focus
    outline none
    border-color $color_primary
    box-shadow $shadow_focus

  &:disabled
    background $color_border_light
    color $color_text_secondary
    cursor not-allowed

// Code Block Pattern
code-block()
  font-family $font_family_mono
  font-size $font_size_sm
  background $color_code_bg
  border 1px solid $color_code_border
  padding $space_lg
  border-radius $radius_base
  overflow-x auto
  line-height 1.5

// Loading Shimmer Animation
loading-shimmer()
  &::after
    content ''
    position absolute
    top 0
    left 0
    right 0
    bottom 0
    background linear-gradient(90deg, transparent, rgba(255,255,255,0.8), transparent)
    animation shimmer 1.5s infinite

// Animation Keyframes
@keyframes shimmer
  0%
    transform translateX(-100%)
  100%
    transform translateX(100%)
