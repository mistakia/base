.hljs-plaintext,
.hljs.language-plaintext
  color: var(--color-text)
  padding: 16px
  font-family: var(--font-family-mono)
  font-size: 0.875rem
  line-height: 1.4
  white-space: pre-wrap
  word-break: break-word

  .number-highlight
    color: var(--color-primary)
    font-weight: var(--font-weight-semibold)
    padding: 1px 3px
    border-radius: 2px
    font-size: 0.9em

  .betting-number
    color: #dc3545
    font-weight: var(--font-weight-semibold)
    font-size: 0.95em
    display: inline-block
    margin: 0 1px
