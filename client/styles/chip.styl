// Chip component - uses design system variables
@import './variables'

.chip
  display inline-flex
  align-items center
  padding 3px $space_sm
  font-family $font_family_mono
  font-size 10px
  font-weight $font_weight_medium
  color $color_text_secondary
  background $color_surface_secondary
  border 1px solid $color_border_light
  border-radius $radius_base
  line-height 1
  white-space nowrap
  transition all $transition_fast

  &:hover
    background darken($color_surface_secondary, 2%)
    border-color darken($color_border_light, 5%)

  // Clickable chip variant (for links)
  &--link
    cursor pointer
    color $color_primary

    &:hover
      background rgba($color_primary, 0.08)
      border-color $color_primary
      text-decoration none
