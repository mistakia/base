.tag-picker-dropdown
  position absolute
  z-index 1000
  background white
  border 1px solid #e0e0e0
  border-radius 4px
  box-shadow 0 2px 8px rgba(0, 0, 0, 0.15)
  min-width 200px
  max-width 300px
  max-height 350px
  display flex
  flex-direction column

.tag-picker-search
  padding 8px
  border-bottom 1px solid #e0e0e0

.tag-picker-search-input
  width 100%
  padding 6px 8px
  border 1px solid #e0e0e0
  border-radius 3px
  font-size 13px
  outline none
  box-sizing border-box

  &:focus
    border-color #90caf9

.tag-picker-list
  overflow-y auto
  padding 4px 0
  flex 1

.tag-picker-empty
  padding 12px
  text-align center
  color #999
  font-size 13px

.tag-picker-option
  display flex
  align-items center
  padding 6px 12px
  cursor pointer
  font-size 13px
  transition background-color 0.1s ease
  gap 8px

  &:hover
    background-color #f5f5f5

  &.tag-picker-option--focused
    background-color #f0f0f0

.tag-picker-check
  width 16px
  text-align center
  font-size 14px
  color #1976d2
  flex-shrink 0

.tag-picker-label
  overflow hidden
  text-overflow ellipsis
  white-space nowrap
