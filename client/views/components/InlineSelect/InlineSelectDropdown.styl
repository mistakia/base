@import '@styles/tasks'

.inline-select-dropdown
  position absolute
  z-index 1000
  background white
  border 1px solid #e0e0e0
  border-radius 4px
  box-shadow 0 2px 8px rgba(0, 0, 0, 0.15)
  min-width 120px
  max-height 300px
  overflow-y auto
  padding 4px 0

.inline-select-option
  padding 8px 12px
  cursor pointer
  font-size 13px
  font-weight 500
  transition background-color 0.1s ease

  &:hover
    background-color #f5f5f5

  &.inline-select-option--selected
    background-color #e3f2fd

  &.inline-select-option--focused
    background-color #f0f0f0

  &.inline-select-option--selected.inline-select-option--focused
    background-color #bbdefb

  // Status colors via data attribute
  &[data-status="completed"]
    color $task_status_colors.completed
  &[data-status="in_progress"]
    color $task_status_colors.in_progress
  &[data-status="started"]
    color $task_status_colors.started
  &[data-status="blocked"]
    color $task_status_colors.blocked
  &[data-status="abandoned"]
    color $task_status_colors.abandoned
  &[data-status="planned"]
    color $task_status_colors.planned
  &[data-status="paused"]
    color $task_status_colors.paused
  &[data-status="waiting"]
    color $task_status_colors.waiting
  &[data-status="no_status"]
    color $task_status_colors.no_status

  // Priority colors via data attribute
  &[data-priority="critical"]
    color $task_priority_colors.critical
  &[data-priority="high"]
    color $task_priority_colors.high
  &[data-priority="medium"]
    color $task_priority_colors.medium
  &[data-priority="low"]
    color $task_priority_colors.low
  &[data-priority="none"]
    color $task_priority_colors.none
