// Home Sessions Panel - Card-based design for homepage
// Uses full-width cards for sessions and threads

.home-sessions-panel
  display: flex
  flex-direction: column
  gap: $space_base
  width: 100%
  max-width: 100%
  min-width: 0
  overflow: visible
  padding-bottom: 12px

.home-sessions-panel__section
  display: flex
  flex-direction: column
  gap: $space_sm
  min-width: 0
  max-width: 100%

.home-sessions-panel__header
  display: flex
  align-items: center
  gap: $space_xs
  padding: $space_xs 0
  font-size: $font_size_xs
  font-weight: $font_weight_semibold
  text-transform: uppercase
  letter-spacing: 0.5px
  color: $color_text_secondary

.home-sessions-panel__header-dot
  width: 8px
  height: 8px
  border-radius: 50%
  flex-shrink: 0

  &--active
    background-color: $color_success
    animation: pulse 1.5s ease-in-out infinite

  &--review
    background-color: $color_warning

.home-sessions-panel__header-title
  flex: 1

.home-sessions-panel__header-count
  font-family: $font_family_mono
  font-size: $font_size_xs
  color: $color_text_tertiary
  background: $color_surface_secondary
  padding: 2px 6px
  border-radius: $radius_sm
  text-decoration: none
  transition: all $transition_fast

  // When used as a link
  &:hover
    color: $color_primary
    background: $color_surface_hover
    text-decoration: none

.home-sessions-panel__list
  display: flex
  flex-direction: column
  gap: $space_sm
  min-width: 0
  max-width: 100%
  overflow: visible

// Active Session Card Styles
.active-session-card
  background: white
  border-radius: $radius_base
  border: 2px solid rgba(40, 167, 69, 0.3)
  padding: $space_sm $space_base
  transition: all $transition_fast
  position: relative
  display: flex
  flex-direction: column
  overflow: visible
  max-width: 100%

  &--clickable
    cursor: pointer

    &:hover
      background-color: $color_surface_hover
      transform: $hover_lift
      box-shadow: $shadow_sm

.active-session-card__main-row
  display: flex
  align-items: center
  gap: $space_xs
  margin-bottom: $space_xs
  min-width: 0
  max-width: 100%

.active-session-card__dot
  width: 8px
  height: 8px
  border-radius: 50%
  background-color: $color_success
  animation: pulse 1.5s ease-in-out infinite
  flex-shrink: 0

  &--idle
    background-color: $color_text_tertiary
    animation: none

.active-session-card__title
  font-size: $font_size_sm
  font-weight: $font_weight_medium
  color: $color_text
  flex: 1
  min-width: 0
  overflow-x: hidden
  overflow-y: visible
  text-overflow: ellipsis
  white-space: nowrap
  line-height: 1.4

.active-session-card__provider
  flex-shrink: 0

.active-session-card__details-row
  display: flex
  align-items: center
  gap: $space_xs
  font-size: $font_size_xs
  color: $color_text_secondary

.active-session-card__status
  color: $color_success
  font-weight: $font_weight_medium

.active-session-card__separator
  color: $color_text_tertiary

.active-session-card__time
  font-family: $font_family_mono
  color: $color_text_tertiary

// Compact Timeline Event Display
.compact-timeline-event
  display: flex
  align-items: center
  gap: $space_xs
  padding: $space_xs $space_sm
  margin-top: $space_xs
  background: $color_surface_secondary
  border-radius: $radius_sm
  font-size: $font_size_xs
  color: $color_text_secondary
  overflow: hidden
  max-width: 100%

  // Message variant with multi-line support
  &--message
    flex-direction: column
    align-items: stretch

.compact-timeline-event__header
  display: flex
  align-items: center
  gap: $space_xs
  width: 100%

.compact-timeline-event__icon
  display: flex
  align-items: center
  flex-shrink: 0
  font-size: 14px
  color: $color_text_tertiary

.compact-timeline-event__label
  flex: 1
  font-weight: $font_weight_medium
  color: $color_text_secondary

.compact-timeline-event__toggle
  display: flex
  align-items: center
  gap: 2px
  padding: 2px 6px
  border: none
  background: transparent
  color: $color_primary
  font-size: $font_size_xs
  cursor: pointer
  border-radius: $radius_sm
  transition: background $transition_fast

  &:hover
    background: rgba(0, 0, 0, 0.05)

.compact-timeline-event__content
  margin-top: $space_xs
  font-size: $font_size_sm
  line-height: 1.5
  color: $color_text
  overflow: hidden
  word-break: break-word
  overflow-wrap: break-word

  // Override MarkdownViewer styles for compact display
  :deep(p)
    margin-bottom: $space_xs
    word-break: break-word

  :deep(p:last-child)
    margin-bottom: 0

  :deep(pre)
    font-size: $font_size_xs
    padding: $space_xs
    margin: $space_xs 0
    overflow-x: auto
    word-break: break-all

  :deep(code)
    font-size: $font_size_xs
    word-break: break-all

.compact-timeline-event__summary
  flex: 1
  min-width: 0
  overflow: hidden
  text-overflow: ellipsis
  white-space: nowrap
  word-break: break-all

// Action Buttons for Idle Sessions
.active-session-card__actions
  display: flex
  align-items: center
  justify-content: flex-end
  gap: $space_xs
  margin-top: $space_sm
  padding-top: $space_sm
  border-top: 1px solid $color_border_light

.active-session-card__action-button
  display: flex
  align-items: center
  justify-content: center
  padding: 4px 8px
  border: 1px solid $color_border_light
  border-radius: $radius_sm
  background: transparent
  color: $color_text_tertiary
  font-size: $font_size_xs
  font-family: $font_family_mono
  text-transform: lowercase
  cursor: pointer
  transition: all $transition_fast

  &:hover
    background: $color_surface_hover
    border-color: $color_border
    color: $color_text

  &:focus
    outline: none
    border-color: $color_primary

  &:active
    background: $color_surface_secondary
