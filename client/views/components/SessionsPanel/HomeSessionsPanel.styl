// Home Sessions Panel - Card-based design for homepage
// Unified styling for session/thread cards

.home-sessions-panel
  display: flex
  flex-direction: column
  gap: $space_sm
  width: 100%
  max-width: 100%
  min-width: 0
  overflow: visible

.home-sessions-panel__section
  display: flex
  flex-direction: column
  gap: $space_sm
  min-width: 0
  max-width: 100%

// Header styles are now shared via .home-section-header in Homepage.styl

.home-sessions-panel__list
  display: flex
  flex-direction: column
  gap: $space_sm
  min-width: 0
  max-width: 100%
  overflow: visible

// =============================================================================
// Session Card - Unified styling for both sessions and threads
// =============================================================================

.session-card
  background: white
  border-radius: $radius_base
  border: 1px solid $color_border_light
  padding: $space_sm $space_base
  transition: all $transition_fast
  position: relative
  display: flex
  flex-direction: column
  overflow: visible
  max-width: 100%

  &--clickable
    cursor: pointer

    &:hover
      transform: $hover_lift
      box-shadow: $shadow_sm

  &--ended
    border-style: dashed

  &--focused
    border-color: $color_primary
    box-shadow: $shadow_focus_subtle

  &--other-user
    opacity: 0.6
    border-left: 2px solid $color_text_tertiary

// Main Row - Title and time
.session-card__main-row
  display: flex
  align-items: center
  gap: $space_xs
  min-width: 0
  max-width: 100%

.session-card__time
  font-size: $font_size_xs
  font-family: $font_family_mono
  color: $color_text_tertiary
  flex-shrink: 0
  display: flex
  align-items: center

.session-card__time-updated
  color: $color_text_secondary

.session-card__time-separator
  margin: 0 2px
  color: $color_text_tertiary
  opacity: 0.5

.session-card__time-created
  color: $color_text_tertiary

.session-card__title
  font-size: $font_size_sm
  font-weight: $font_weight_medium
  color: $color_text
  flex: 1
  min-width: 0
  overflow: hidden
  text-overflow: ellipsis
  white-space: nowrap
  line-height: 1.4

// Footer Row - Details on left, actions on right
.session-card__footer
  display: flex
  align-items: center
  justify-content: space-between
  gap: $space_sm
  margin-top: $space_xs
  padding-top: $space_xs
  border-top: 1px solid $color_border_light
  font-size: $font_size_xs
  color: $color_text_secondary

.session-card__details
  display: flex
  align-items: center
  gap: $space_xs
  min-width: 0
  flex: 1

.session-card__directory
  font-family: $font_family_mono
  overflow: hidden
  text-overflow: ellipsis
  white-space: nowrap
  flex-shrink: 1
  min-width: 0

.session-card__separator
  color: $color_text_tertiary
  flex-shrink: 0

.session-card__stat
  font-family: $font_family_mono
  flex-shrink: 0

// =============================================================================
// Compact Timeline Event Display
// =============================================================================

.compact-timeline-event
  display: flex
  align-items: center
  gap: $space_xs
  padding: $space_xs $space_sm
  margin-top: $space_xs
  background: rgba($breadcrumb_light_color, 0.4)
  border-radius: $radius_sm
  font-size: $font_size_xs
  color: $color_text_secondary
  overflow: hidden
  max-width: 100%

  // Message variant with multi-line support
  &--message
    flex-direction: column
    align-items: stretch

.compact-timeline-event__header
  display: flex
  align-items: center
  gap: $space_xs
  width: 100%

.compact-timeline-event__label
  flex: 1
  font-weight: $font_weight_medium
  color: $color_text_secondary

.compact-timeline-event__content
  margin-top: $space_xs
  font-size: $font_size_sm
  line-height: 1.5
  color: $color_text
  overflow: hidden
  word-break: break-word
  overflow-wrap: break-word

  // Override MarkdownViewer styles for compact display
  p
    margin-bottom: $space_xs
    word-break: break-word

  p:last-child
    margin-bottom: 0

  pre
    font-size: $font_size_xs
    padding: $space_xs
    margin: $space_xs 0
    overflow-x: auto
    word-break: break-all

  code
    font-size: $font_size_xs
    word-break: break-all

.compact-timeline-event__summary
  flex: 1
  min-width: 0
  overflow: hidden
  text-overflow: ellipsis
  white-space: nowrap
  word-break: break-all

// =============================================================================
// Action Buttons - For idle sessions
// =============================================================================

.session-card__actions
  display: flex
  align-items: center
  gap: $space_xs
  flex-shrink: 0

.session-card__action-button
  display: flex
  align-items: center
  justify-content: center
  padding: 4px 8px
  border: 1px solid $color_border_light
  border-radius: $radius_sm
  background: transparent
  color: $color_text_tertiary
  font-size: $font_size_xs
  font-family: $font_family_mono
  text-transform: lowercase
  cursor: pointer
  transition: all $transition_fast

  &:hover
    background: $color_surface_hover
    border-color: $color_border
    color: $color_text

  &:focus
    outline: none
    border-color: $color_primary

  &:active
    background: $color_surface_secondary

  &--danger
    border-color: $color_error
    color: $color_error

    &:hover
      background: $color_error
      color: white

  &--confirming
    background: $color_error
    color: white
    border-color: $color_error

    &:hover
      background: darken($color_error, 10%)
      border-color: darken($color_error, 10%)

// =============================================================================
// Responsive Design
// =============================================================================

@media (max-width: 768px)
  .session-card
    border-radius: 0
    border-left: none
    border-right: none
    margin-left: (-$space_base)
    margin-right: (-$space_base)
