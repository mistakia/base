// Home Sessions Panel - Card-based design for homepage
// Uses full-width cards for sessions and threads

.home-sessions-panel
  display: flex
  flex-direction: column
  gap: $space_sm
  width: 100%
  max-width: 100%
  min-width: 0
  overflow: visible

.home-sessions-panel__section
  display: flex
  flex-direction: column
  gap: $space_sm
  min-width: 0
  max-width: 100%

// Header styles are now shared via .home-section-header in Homepage.styl

.home-sessions-panel__list
  display: flex
  flex-direction: column
  gap: $space_sm
  min-width: 0
  max-width: 100%
  overflow: visible

// Active Session Card Styles
.active-session-card
  background: white
  border-radius: $radius_base
  border: 1px solid transparent
  padding: $space_sm $space_base
  transition: all $transition_fast
  position: relative
  display: flex
  flex-direction: column
  overflow: visible
  max-width: 100%

  &--active
    animation: border-pulse 1.5s ease-in-out infinite

  &--clickable
    cursor: pointer

    &:hover
      transform: $hover_lift
      box-shadow: $shadow_sm

@keyframes border-pulse
  0%, 100%
    border-color: rgba(40, 167, 69, 0.3)
  50%
    border-color: rgba(40, 167, 69, 0.7)

.active-session-card__header-row
  display: flex
  align-items: center
  gap: $space_xs
  min-width: 0
  max-width: 100%

.active-session-card__status
  font-size: $font_size_xs
  color: $color_success
  font-weight: $font_weight_medium
  flex-shrink: 0

.active-session-card__time
  font-size: $font_size_xs
  font-family: $font_family_mono
  color: $color_text_tertiary
  flex-shrink: 0
  margin-right: $space_sm

.active-session-card__title
  font-size: $font_size_sm
  font-weight: $font_weight_medium
  color: $color_text
  flex: 1
  min-width: 0
  overflow-x: hidden
  overflow-y: visible
  text-overflow: ellipsis
  white-space: nowrap
  line-height: 1.4

// Compact Timeline Event Display
.compact-timeline-event
  display: flex
  align-items: center
  gap: $space_xs
  padding: $space_xs $space_sm
  margin-top: $space_xs
  background: rgba($breadcrumb_light_color, 0.4)
  border-radius: $radius_sm
  font-size: $font_size_xs
  color: $color_text_secondary
  overflow: hidden
  max-width: 100%

  // Message variant with multi-line support
  &--message
    flex-direction: column
    align-items: stretch

.compact-timeline-event__header
  display: flex
  align-items: center
  gap: $space_xs
  width: 100%

.compact-timeline-event__label
  flex: 1
  font-weight: $font_weight_medium
  color: $color_text_secondary

.compact-timeline-event__toggle
  display: flex
  align-items: center
  gap: 2px
  padding: 2px 6px
  border: none
  background: transparent
  color: $color_primary
  font-size: $font_size_xs
  cursor: pointer
  border-radius: $radius_sm
  transition: background $transition_fast

  &:hover
    background: rgba(0, 0, 0, 0.05)

.compact-timeline-event__content
  margin-top: $space_xs
  font-size: $font_size_sm
  line-height: 1.5
  color: $color_text
  overflow: hidden
  word-break: break-word
  overflow-wrap: break-word

  // Override MarkdownViewer styles for compact display
  p
    margin-bottom: $space_xs
    word-break: break-word

  p:last-child
    margin-bottom: 0

  pre
    font-size: $font_size_xs
    padding: $space_xs
    margin: $space_xs 0
    overflow-x: auto
    word-break: break-all

  code
    font-size: $font_size_xs
    word-break: break-all

.compact-timeline-event__summary
  flex: 1
  min-width: 0
  overflow: hidden
  text-overflow: ellipsis
  white-space: nowrap
  word-break: break-all

// Action Buttons for Idle Sessions
.active-session-card__actions
  display: flex
  align-items: center
  justify-content: flex-end
  gap: $space_xs
  margin-top: $space_sm
  padding-top: $space_sm
  border-top: 1px solid $color_border_light

.active-session-card__action-button
  display: flex
  align-items: center
  justify-content: center
  padding: 4px 8px
  border: 1px solid $color_border_light
  border-radius: $radius_sm
  background: transparent
  color: $color_text_tertiary
  font-size: $font_size_xs
  font-family: $font_family_mono
  text-transform: lowercase
  cursor: pointer
  transition: all $transition_fast

  &:hover
    background: $color_surface_hover
    border-color: $color_border
    color: $color_text

  &:focus
    outline: none
    border-color: $color_primary

  &:active
    background: $color_surface_secondary
