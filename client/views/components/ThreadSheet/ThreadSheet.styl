@import '@styles/variables'

$sheet_width = 480px

// Global layout adjustment when panel is open
html.thread-sheet-open
  margin-right $sheet_width
  transition margin-right $transition_layout

  @media (max-width: 768px)
    margin-right 0

  // Adjust fixed-position bottom bar to stop at the panel edge
  .bottom-bar
    right $sheet_width
    transition right $transition_layout

    @media (max-width: 768px)
      right 0

// Container for all stacked sheets - always mounted, slides in/out via transform
.thread-sheet__container
  position: fixed
  top: 0
  right: 0
  bottom: 0
  width: $sheet_width
  max-width: 95vw
  z-index: 1200
  transform: translateX(100%)
  transition: transform $transition_layout
  pointer-events: none

  &--open
    transform: translateX(0)
    pointer-events: auto

  @media (max-width: 768px)
    top: auto
    bottom: 0
    left: 0
    width: 100%
    height: 95vh
    max-width: 100%
    transform: translateY(100%)

    &--open
      transform: translateY(0)

// Individual sheet panel
.thread-sheet__panel
  position: relative
  height: 100%
  background: $color_surface
  border-left: 1px solid $color_border_light
  display: flex
  flex-direction: column

  @media (max-width: 768px)
    border-left: none
    border-top: 1px solid $color_border_light

// ============================================================================
// Header area: ThreadHeader with sheet overrides
// ============================================================================

.thread-sheet__header-area
  flex-shrink: 0
  border-bottom: 1px solid $color_border_light
  max-height: 50vh
  overflow-y: auto

.thread-sheet__close
  flex-shrink: 0
  background: none
  border: none
  cursor: pointer
  width: 28px
  height: 28px
  display: flex
  align-items: center
  justify-content: center
  color: $color_text_tertiary
  transition: color $transition_fast

  &:hover
    color: $color_text

// Session-only sheet header (simple bar before thread data exists)
.thread-sheet__session-header
  flex-shrink: 0
  display: flex
  align-items: center
  gap: $space_sm
  padding: $space_sm $space_base
  border-bottom: 1px solid $color_border_light
  min-height: 44px

.thread-sheet__session-title
  font-size: $font_size_sm
  font-weight: $font_weight_semibold
  color: $color_text
  white-space: nowrap
  overflow: hidden
  text-overflow: ellipsis
  flex: 1
  min-width: 0

.thread-sheet__metadata-state
  font-size: $font_size_xs
  font-weight: $font_weight_medium
  padding: 1px 6px
  border-radius: $radius_sm
  white-space: nowrap
  flex-shrink: 0
  text-transform: lowercase

  &--active
    background: rgba(40, 167, 69, 0.1)
    color: $color_success

  &--archived
    background: rgba(108, 117, 125, 0.1)
    color: $color_text_secondary

// ============================================================================
// Scrollable timeline area
// ============================================================================

.thread-sheet__scroll-area
  flex: 1
  overflow-y: auto
  overflow-x: hidden
  padding: $space_sm $space_base
  padding-bottom: 64px

// Loading / error / empty states
.thread-sheet__loading,
.thread-sheet__error,
.thread-sheet__empty
  padding: $space_lg
  font-size: $font_size_sm
  color: $color_text_secondary
  text-align: center

.thread-sheet__error
  color: $color_error

.thread-sheet__timeline
  min-width: 0

// Override scroll-to-bottom button in sheet context: position above floating input
.thread-sheet__scroll-area .timeline-scroll-button
  position: sticky
  bottom: 48px
  z-index: 2

// ============================================================================
// Resume status indicator
// ============================================================================

.thread-sheet__resume-status
  flex-shrink: 0
  display: flex
  flex-direction: column
  gap: 4px
  padding: $space_sm $space_base
  font-size: $font_size_xs
  color: $color_text_secondary
  border-top: 1px solid $color_border_light

  &--failed
    color: $color_error

.thread-sheet__resume-status-header
  display: flex
  align-items: center
  gap: 6px

.thread-sheet__resume-status-badge
  font-size: 10px
  font-weight: $font_weight_semibold
  text-transform: uppercase
  letter-spacing: 0.04em
  color: $color_text_tertiary

  .thread-sheet__resume-status--failed &
    color: $color_error

.thread-sheet__resume-status-prompt
  color: $color_text
  line-height: 1.4
  overflow: hidden
  display: -webkit-box
  -webkit-line-clamp: 3
  -webkit-box-orient: vertical

.thread-sheet__resume-status-error
  line-height: 1.4

// ============================================================================
// Floating thread input at bottom
// ============================================================================

.thread-sheet__input
  position: absolute
  bottom: $space_base
  left: $space_sm
  right: $space_sm
  z-index: 1

.thread-sheet__input-form
  display: flex
  flex-direction: column
  background: var(--color-bg, #ffffff)
  border-radius: 4px
  border: 1px solid var(--color-border-light, #e8e8e8)
  padding: $space_sm $space_sm

.thread-sheet__input-field
  border: none
  padding: 0
  font-family: inherit
  font-size: $font_size_base
  color: var(--color-text, #1a1a1a)
  outline: none
  background: transparent
  line-height: 1.4
  min-width: 0
  resize: none
  min-height: 20px
  max-height: 160px
  overflow-y: auto

  &::placeholder
    color: var(--color-text-tertiary, #999)

  &:disabled
    opacity: 0.5

.thread-sheet__input-bottom-row
  display: flex
  align-items: center
  justify-content: flex-end
  padding-top: $space_xs

.thread-sheet__input-send
  flex-shrink: 0
  min-width: auto
  width: 24px
  height: 24px
  padding: 0
  border-radius: 0
  background-color: var(--color-breadcrumb-dark)
  transform: scale(0)
  opacity: 0
  transition: transform 0.25s cubic-bezier(0.34, 1.56, 0.64, 1), opacity 0.2s ease

  &--visible
    transform: scale(1)
    opacity: 1

  &:hover
    opacity: 0.9

  &.Mui-disabled
    background-color: var(--color-border-light)
    color: var(--color-text-tertiary)
