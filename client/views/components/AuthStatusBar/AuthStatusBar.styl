$status_bar_color = #000000

.auth-status-bar
  max-width 1100px
  margin 40px auto 0
  height: 40px
  color: $status_bar_color
  z-index: 1000
  display: flex
  justify-content: center
  align-items: center

  &__container
    width: 100%
    max-width: 1100px
    margin: 0 auto
    padding: 0 var(--space-base)
    display: flex
    align-items: center
    justify-content: center
    height: 100%

  &:hover
    background-color: rgba(0,0,0,0.02)

.auth-status-bar__clear-key
  background: none
  border: none
  color: rgba(0, 0, 0, 0.4)
  font-size: var(--font-size-base)
  cursor: pointer
  padding: 0
  width: 20px
  height: 20px
  border-radius: 50%
  transition: all 0.2s ease
  margin-left: var(--space-sm)
  
  &:hover
    color: rgba(0, 0, 0, 0.8)
    background: rgba(0, 0, 0, 0.1)

.auth-status-bar--no-key
  .auth-status-bar__container
    justify-content: center
    gap: var(--space-sm)
    
  .auth-status-bar__input-container
    display: flex
    align-items: center
    justify-content: center
    width: 100%
    max-width: 600px
    position: relative

  .auth-status-bar__tint-text
    position: absolute
    left: 50%
    top: 50%
    transform: translate(-50%, -50%)
    color: rgba(0, 0, 0, 0.04)
    font-family: var(--font-family-mono)
    font-size: var(--font-size-xl)
    font-weight: 900
    pointer-events: none
    z-index: 1
    transition: opacity 0.2s ease
    letter-spacing: 0.5em

  .auth-status-bar__key-input
    width: 100%
    padding: var(--space-xs) var(--space-sm)
    background: transparent
    border: 1px solid transparent
    color: $status_bar_color
    font-family: var(--font-family-mono)
    font-size: var(--font-size-base)
    text-align: center
    transition: all 0.2s ease
    
    &::after
      content: ''
      position: absolute
      bottom: 0
      left: 0
      height: 2px
      background: linear-gradient(90deg, rgba(76, 175, 80, 0.3) 0%, rgba(76, 175, 80, 0.8) 100%)
      width: calc((var(--char-count, 0) / 64) * 100%)
      transition: width 0.3s ease
      border-radius: 1px
    
    &::placeholder
      color: transparent
      transition: color 0.2s ease
      
    &:focus
      outline: none
      
    &:focus::placeholder
      color: rgba(0, 0, 0, 0.4)

  &:hover
    .auth-status-bar__tint-text
      opacity: 0
      
    .auth-status-bar__key-input::placeholder
      color: rgba(0, 0, 0, 0.4)

  .auth-status-bar__char-count
    position: absolute
    right: -40px
    top: 50%
    transform: translateY(-50%)
    color: rgba(0, 0, 0, 0.6)
    font-size: var(--font-size-xs)
    font-family: var(--font-family-mono)
    pointer-events: none
    
    &.ready
      color: rgba(76, 175, 80, 0.8)

  .auth-status-bar__error
    position: absolute
    top: 100%
    left: 50%
    transform: translateX(-50%)
    background: rgba(220, 53, 69, 0.7)
    color: $status_bar_color
    font-size: var(--font-size-xs)
    padding: var(--space-xs) var(--space-sm)
    border-radius: 0 0 var(--radius-sm) var(--radius-sm)
    margin-top: var(--space-xs)
    z-index: 1001
    white-space: nowrap

.auth-status-bar--loading
  .auth-status-bar__container
    justify-content: center
    gap: var(--space-sm)
    
  .auth-status-bar__status
    display: flex
    align-items: center
    justify-content: center
    gap: var(--space-base)
    width: 100%
    
  .auth-status-bar__key
    font-family: var(--font-family-mono)
    font-size: var(--font-size-sm)
    color: $status_bar_color
    
  .auth-status-bar__loading
    font-size: var(--font-size-sm)
    color: $status_bar_color
    
    &::after
      content: ''
      display: inline-block
      width: 8px
      height: 8px
      margin-left: var(--space-xs)
      border: 1px solid rgba(255, 255, 255, 0.3)
      border-top-color: rgba(255, 255, 255, 0.7)
      border-radius: 50%
      animation: spin 1s linear infinite

.auth-status-bar--authenticated
  border: 3px solid rgba(0, 0, 0, 0.1)
  border-radius: var(--radius-sm)
  
  .auth-status-bar__container
    justify-content: space-between
    gap: var(--space-sm)
  
  .auth-status-bar__user-info
    display: flex
    flex-direction: column
    align-items: flex-start
    gap: 2px
    flex: 1
    justify-content: center
    height: 100%
  
  .auth-status-bar__username
    font-size: var(--font-size-base)
    color: $status_bar_color
    font-weight: 500
    line-height: 1
  
  .auth-status-bar__public-key
    font-size: var(--font-size-xs)
    color: rgba(0, 0, 0, 0.5)
    font-family: var(--font-family-mono)
    line-height: 1

@keyframes spin
  0%
    transform: rotate(0deg)
  100%
    transform: rotate(360deg)