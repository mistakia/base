@import '@styles/variables'

.auth-status-bar
  color: $color_text
  z-index: 1000
  display: flex
  align-items: center
  font-family: $font_family_mono

  &__container
    display: flex
    align-items: center
    height: 100%

    &--clickable
      cursor: pointer

.auth-status-bar--no-key
.auth-status-bar--loading
  max-width: 1100px
  margin: 40px auto 0
  height: 40px
  justify-content: center

  .auth-status-bar__container
    width: 100%
    max-width: 1100px
    margin: 0 auto
    padding: 0 $space_base
    justify-content: center

  &:hover
    background-color: $color_surface_hover

.auth-status-bar--no-key
  .auth-status-bar__container
    justify-content: center
    gap: $space_sm

  .auth-status-bar__input-container
    display: flex
    align-items: center
    justify-content: center
    width: 100%
    max-width: 600px
    position: relative

  .auth-status-bar__tint-text
    position: absolute
    left: 50%
    top: 50%
    transform: translate(-50%, -50%)
    color: $color_border_light
    font-family: $font_family_mono
    font-size: $font_size_xl
    font-weight: $font_weight_bold
    pointer-events: none
    z-index: 1
    transition: opacity $transition_fast
    letter-spacing: 0.5em

  .auth-status-bar__key-input
    width: 100%
    padding: $space_xs $space_sm
    background: transparent
    border: 1px solid transparent
    color: $color_text
    font-family: $font_family_mono
    font-size: $font_size_base
    text-align: center
    transition: all $transition_base

    &::after
      content: ''
      position: absolute
      bottom: 0
      left: 0
      height: 2px
      background: linear-gradient(90deg, rgba(76, 175, 80, 0.3) 0%, rgba(76, 175, 80, 0.8) 100%)
      width: calc((var(--char-count, 0) / 64) * 100%)
      transition: width $transition_layout
      border-radius: 1px

    &::placeholder
      color: transparent
      transition: color $transition_fast

    &:focus
      outline: none

    &:focus::placeholder
      color: $color_text_secondary

  &:hover
    .auth-status-bar__tint-text
      opacity: 0

    .auth-status-bar__key-input::placeholder
      color: $color_text_secondary

  .auth-status-bar__char-count
    position: absolute
    right: -40px
    top: 50%
    transform: translateY(-50%)
    color: $color_text_secondary
    font-size: $font_size_xs
    font-family: $font_family_mono
    pointer-events: none

    &.ready
      color: $color_success

  .auth-status-bar__error
    position: absolute
    top: 100%
    left: 50%
    transform: translateX(-50%)
    background: $color_error
    color: $color_white
    font-size: $font_size_xs
    padding: $space_xs $space_sm
    border-radius: 0
    margin-top: $space_xs
    z-index: 1001
    white-space: nowrap

.auth-status-bar--loading
  .auth-status-bar__container
    justify-content: center
    gap: $space_sm

  .auth-status-bar__status
    display: flex
    align-items: center
    justify-content: center
    gap: $space_base
    width: 100%

  .auth-status-bar__key
    font-family: $font_family_mono
    font-size: $font_size_sm
    color: $color_text

  .auth-status-bar__loading
    font-size: $font_size_sm
    color: $color_text_secondary

    &::after
      content: ''
      display: inline-block
      width: 8px
      height: 8px
      margin-left: $space_xs
      border: 1px solid $color_border
      border-top-color: $color_text_secondary
      border-radius: 50%
      animation: spin 1s linear infinite

.auth-status-bar--authenticated
  display: inline-flex
  width: auto
  margin-left: auto

  .auth-status-bar__container
    border: 1px solid $color_border_light
    padding: $space_xs $space_sm
    gap: $space_sm
    transition: background $transition_fast, border-color $transition_fast

    &:hover
      background: $color_surface_hover
      border-color: $color_border

  .auth-status-bar__user-info
    display: flex
    flex-direction: row
    align-items: baseline
    gap: $space_sm

  .auth-status-bar__username
    font-size: $font_size_sm
    color: $color_text
    font-weight: $font_weight_medium
    line-height: 1
    white-space: nowrap

  .auth-status-bar__public-key
    font-size: $font_size_xs
    color: $color_text_secondary
    font-family: $font_family_mono
    line-height: 1
    white-space: nowrap

@keyframes spin
  0%
    transform: rotate(0deg)
  100%
    transform: rotate(360deg)
