.code-viewer
  background-color #f6f8fa
  border 1px solid #d0d7de
  border-radius 0.375rem
  overflow hidden

.code-header
  background-color #f6f8fa
  border-bottom 1px solid #d0d7de
  padding 0.5rem 1rem
  font-size 0.75rem
  color #656d76

.code-language
  font-weight 600
  text-transform uppercase

.code-content
  margin 0
  padding 1rem
  font-family 'Monaco', 'Menlo', 'Ubuntu Mono', monospace
  font-size 0.875rem
  line-height 1.45
  overflow-x auto
  background-color #ffffff

  code
    background transparent
    padding 0
    font-size inherit
    font-family inherit