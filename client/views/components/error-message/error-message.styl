.error-message
  display flex
  align-items flex-start
  gap 1rem
  padding 1.5rem
  background-color #fff5f5
  border 1px solid #fed7d7
  border-radius 0.375rem
  color #742a2a

.error-icon
  font-size 1.5rem
  flex-shrink 0

.error-content
  flex 1

.error-title
  margin 0 0 0.5rem 0
  font-size 1rem
  font-weight 600

.error-text
  margin 0
  font-size 0.875rem
  line-height 1.25