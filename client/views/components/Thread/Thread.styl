.thread-card
  background: white
  border-radius: $radius_base
  border: 2px solid $color_border_light
  padding: $space_sm $space_base
  cursor: pointer
  transition: all $transition_fast
  position: relative
  display: flex
  flex-direction: column

  &:hover
    background-color: $color_surface_hover
    transform: $hover_lift
    box-shadow: $shadow_sm

  &--focused
    border-color: $color_primary
    box-shadow: $shadow_focus_subtle

.thread-main-row
  display: flex
  align-items: center
  gap: $space_xs
  margin-bottom: $space_xs

.thread-status
  flex-shrink: 0

.thread-time
  font-size: $font_size_xs
  color: $color_text_tertiary
  font-family: $font_family_mono
  flex-shrink: 0

.thread-title
  font-size: $font_size_sm
  line-height: 1.2
  font-weight: $font_weight_medium
  color: $color_text
  flex: 1
  overflow: hidden
  text-overflow: ellipsis
  white-space: nowrap
  margin-left: $space_xs

.thread-provider
  flex-shrink: 0

.thread-details-row
  display: flex
  align-items: flex-start
  gap: $space_xs
  margin: 0 -16px 0 -16px
  padding: $space_xs $space_base
  border-bottom-left-radius: $radius_base
  border-bottom-right-radius: $radius_base
  font-size: $font_size_xs
  color: $color_text_secondary
  width: fit-content

.thread-working-directory
  font-family: $font_family_mono
  overflow: hidden
  text-overflow: ellipsis
  white-space: nowrap
  flex: 1

.thread-separator
  color: $color_text_tertiary
  flex-shrink: 0

.thread-duration
  font-family: $font_family_mono
  flex-shrink: 0

// Responsive adjustments for mobile
@media (max-width: 768px)
  .thread-card
    border-radius: 0
    border-left: none
    border-right: none
    margin-left: (-$space_base)
    margin-right: (-$space_base)

  .thread-main-row
    flex-wrap: wrap

  .thread-title
    order: 1
    flex-basis: 100%
    margin-left: 0
    margin-bottom: $space_xs

  .thread-status
    order: 2

  .thread-time
    order: 3

  .thread-provider
    order: 4
    margin-left: auto