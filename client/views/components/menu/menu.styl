.menu__sidebar
  width 240px
  min-height 100vh
  display flex
  flex-direction column
  padding 64px 16px 4px
  font-family Inter, system-ui, sans-serif

.menu__content
  flex 1
  display flex
  flex-direction column
  gap 24px

.menu__list
  list-style none
  margin 0
  padding 0
  display flex
  flex-direction column
  gap 2px

.menu__item
  display flex
  align-items center
  width 100%
  min-height 27px
  height 30px
  padding 4px 8px
  font-size 14px
  font-family ui-sans-serif, -apple-system, BlinkMacSystemFont, "Segoe UI Variable Display", "Segoe UI", Helvetica, "Apple Color Emoji", Arial, sans-serif, "Segoe UI Emoji", "Segoe UI Symbol"
  color rgb(50, 48, 44)
  border-radius 6px
  margin-left 0px
  margin-right 0px
  font-weight 400
  cursor pointer
  user-select none
  transition background 150ms
  box-sizing border-box
  outline 0
  isolation isolate
  text-decoration none
  border none
  overflow hidden
  text-overflow clip
  white-space nowrap

.menu__item--active
  background #ececec
  font-weight 600

.menu__item:hover
  background #f5f5f4

.menu__section
  display flex
  flex-direction column
  gap 8px

.menu__section-header
  font-size 12px
  font-weight 600
  color rgb(107, 114, 126)
  text-transform uppercase
  letter-spacing 0.5px
  padding 4px 8px

.menu__directory-list
  list-style none
  margin 0
  padding 0
  display flex
  flex-direction column
  gap 1px

.menu__directory-container
  list-style none

.menu__directory-item
  display flex
  align-items center
  width 100%
  min-height 24px
  height 28px
  padding 4px 8px
  font-size 13px
  font-family ui-sans-serif, -apple-system, BlinkMacSystemFont, "Segoe UI Variable Display", "Segoe UI", Helvetica, "Apple Color Emoji", Arial, sans-serif, "Segoe UI Emoji", "Segoe UI Symbol"
  color rgb(55, 53, 47)
  border-radius 4px
  margin-left 0px
  margin-right 0px
  font-weight 400
  user-select none
  transition background 150ms
  box-sizing border-box
  outline 0
  isolation isolate
  text-decoration none
  border none
  overflow hidden
  text-overflow ellipsis
  white-space nowrap

.menu__directory-item:hover
  background #e9ecef

.menu__expand-button
  display flex
  align-items center
  justify-content center
  width 20px
  height 20px
  margin-right 4px
  padding 0
  background none
  border none
  cursor pointer
  color rgb(145, 145, 142)
  border-radius 2px
  transition background 150ms

.menu__expand-button:hover
  background rgba(145, 145, 142, 0.1)

.menu__expand-button--hidden
  visibility hidden
  pointer-events none

.menu__directory-content
  display flex
  align-items center
  flex 1
  cursor pointer
  padding 2px 0

.menu__subdirectory-list
  list-style none
  margin 0
  padding 0
  display flex
  flex-direction column