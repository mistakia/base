@import '../../../styles/mixins'

.task-item
  grid-item()
  padding $space_base
  margin-bottom $space_base

  .task-title
    font-family $font_family_mono
    font-size $font_size_lg
    font-weight $font_weight_semibold
    color $color_text
    margin-bottom $space_sm

  .task-status,
  .task-priority
    status-badge()
    margin-right $space_base
    margin-bottom $space_sm

  .task-status
    background-color $color_success_subtle
    color $color_success

  .task-priority
    background-color $color_warning_subtle
    color $color_warning

  .task-description
    font-family $font_family_mono
    font-size $font_size_base
    color $color_text_secondary
    line-height 1.4

  // Preview variant
  &.task-item-preview
    list-item()
    margin-bottom 0

    &:last-child
      border-bottom none

    .task-description
      display -webkit-box
      -webkit-line-clamp 2
      -webkit-box-orient vertical
      overflow hidden

  // Detailed variant
  &.task-item-detailed
    padding $space_lg
    border 1px solid $color_border
    box-shadow $shadow_sm

    .task-title
      font-size $font_size_2xl
      margin-bottom $space_base

    .task-description
      margin-top $space_base
      white-space pre-wrap