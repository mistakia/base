.error-boundary-fallback
  display flex
  flex-direction column
  align-items center
  justify-content center
  padding 16px
  text-align center
  background $color_surface
  border 1px solid $color_border
  border-radius 8px
  margin 8px 0

  h3
    color $color_danger
    margin 0 0 8px 0
    font-size 16px
    font-weight 500

  .error-message
    color $color_text_secondary
    font-size 14px
    margin 0 0 16px 0

  .retry-button
    padding 8px 16px
    background $color_primary
    color white
    border none
    border-radius 4px
    font-size 14px
    cursor pointer
    transition background 0.2s

    &:hover
      background $color_primary_hover

    &:focus
      outline none
      box-shadow 0 0 0 2px rgba($primary_color_rgb, 0.2) 