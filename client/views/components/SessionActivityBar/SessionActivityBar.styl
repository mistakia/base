.session-activity-bar
  display flex
  align-items center
  gap 8px
  padding 12px 16px
  margin-top 8px
  margin-bottom 8px
  border-radius 8px
  font-size 13px
  font-weight 500

  &--active
    background-color rgba(76, 175, 80, 0.08)
    border 1px solid rgba(76, 175, 80, 0.2)
    color #4caf50

  &--idle
    background-color rgba(255, 193, 7, 0.08)
    border 1px solid rgba(255, 193, 7, 0.2)
    color #ffc107

  &--pending
  &--queued
    background-color rgba(33, 150, 243, 0.08)
    border 1px solid rgba(33, 150, 243, 0.2)
    color #2196f3

  &--compact
    display inline
    padding 0
    margin 0
    border none
    background none
    border-radius 0
    font-size 12px

  &__dot
    width 8px
    height 8px
    border-radius 50%
    background-color currentColor
    flex-shrink 0
    animation session-activity-pulse 1.5s ease-in-out infinite

  &__text
    white-space nowrap
    overflow hidden
    text-overflow ellipsis
    font-family 'SF Mono', 'Monaco', 'Menlo', 'Consolas', monospace
    font-size 13px

@keyframes session-activity-pulse
  0%, 100%
    opacity 1
  50%
    opacity 0.4
