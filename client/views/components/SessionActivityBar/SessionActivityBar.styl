@import '@styles/variables'

.session-activity-bar
  display flex
  align-items center
  gap $space_sm
  padding $space_sm 0
  margin-top $space_sm
  margin-bottom $space_sm
  border-radius 0
  background transparent
  font-size $font_size_sm
  font-weight $font_weight_medium

  &--active
    color $color_success

  &--idle
    color $color_warning

  &--pending
  &--queued
    color $color_info

  &--compact
    display inline
    padding 0
    margin 0
    border none
    background none
    border-radius 0
    font-size $font_size_sm
    font-family $font_family_mono
    flex-shrink 0

  &__dot
    width 6px
    height 6px
    border-radius 50%
    background-color currentColor
    flex-shrink 0
    animation session-activity-pulse 1.2s ease-in-out infinite

  &__text
    white-space nowrap
    overflow hidden
    text-overflow ellipsis
    font-family $font_family_mono
    font-size $font_size_sm

@keyframes session-activity-pulse
  0%, 100%
    opacity 1
  50%
    opacity 0.4
