.thread-list-container
  display flex
  flex-direction column
  gap 12px
  padding 16px

.thread-item
  display flex
  flex-direction column
  padding 12px 16px
  border-radius 8px
  background $color_surface
  text-decoration none
  color $color_text
  border 1px solid $color_border
  
  &:hover
    background $color_surface_hover
  
  &.active
    border-color $color_primary

.thread-title
  font-size 16px
  font-weight 500
  margin-bottom 4px

.thread-meta
  display flex
  justify-content space-between
  font-size 12px
  color $color_text_secondary

.thread-model
  font-size 12px
  color $color_text_secondary
  margin-bottom 8px

.thread-state
  display inline-block
  padding 2px 6px
  border-radius 4px
  font-size 12px
  font-weight 500
  
  &.active
    background $color_success_subtle
    color $color_success
  
  &.paused
    background $color_warning_subtle
    color $color_warning
  
  &.terminated
    background $color_danger_subtle
    color $color_danger

.empty-state
  display flex
  flex-direction column
  align-items center
  justify-content center
  padding 48px 16px
  text-align center
  color $color_text_secondary
  
  h3
    margin-bottom 8px
  
  p
    margin-bottom 16px

.create-button
  display inline-flex
  align-items center
  justify-content center
  padding 8px 16px
  border-radius 4px
  background $color_primary
  color white
  text-decoration none
  font-weight 500
  transition background 0.2s
  
  &:hover
    background $color_primary_hover

.loading-state
  padding 24px
  text-align center
  color $color_text_secondary

.error-state
  padding 24px
  text-align center
  color $color_danger 