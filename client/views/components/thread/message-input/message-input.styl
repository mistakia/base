.message-input-container
  display flex
  flex-direction column
  padding 16px
  border-top 1px solid $border_color
  background $background_color

  form
    position relative
    width 100%

    textarea
      width 100%
      min-height 48px
      max-height 200px
      padding 12px 16px
      padding-right 48px
      border-radius 8px
      border 1px solid $border_color
      font-family inherit
      font-size 14px
      line-height 1.5
      resize none
      background $background_color
      color $text_color
      
      &:focus
        outline none
        border-color $primary_color
        box-shadow 0 0 0 2px rgba($primary_color_rgb, 0.2)
      
      &::placeholder
        color $text_color_tertiary
      
      &:disabled
        background $input_disabled_color
        cursor not-allowed

    button
      position absolute
      right 8px
      bottom 8px
      width 32px
      height 32px
      border-radius 50%
      display flex
      align-items center
      justify-content center
      background $primary_color
      color white
      border none
      cursor pointer
      transition background 0.2s
      
      &:hover
        background $primary_color_hover
      
      &:disabled
        background $primary_color_disabled
        cursor not-allowed
      
      svg
        width 16px
        height 16px

  .input-info
    margin-top 8px
    font-size 12px
    color $text_color_secondary
    text-align right 