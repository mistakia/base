@import '../../../../styles/mixins'

.message-input-container
  display flex
  flex-direction column
  padding $space_base
  border-top 1px solid $color_border
  background $color_surface

  form
    position relative
    width 100%

    textarea
      form-control()
      width 100%
      min-height 48px
      max-height 200px
      padding-right 48px
      resize none
      
      &::placeholder
        color $color_text_tertiary

    button
      position absolute
      right $space_sm
      bottom $space_sm
      width 32px
      height 32px
      border-radius 50%
      display flex
      align-items center
      justify-content center
      background $color_primary
      color white
      border none
      cursor pointer
      transition background $transition_base
      
      &:hover
        background $color_primary_hover
      
      &:disabled
        background $color_primary_disabled
        cursor not-allowed
      
      svg
        width 16px
        height 16px

  .input-info
    margin-top $space_sm
    font-family $font_family_mono
    font-size $font_size_xs
    color $color_text_secondary
    text-align right