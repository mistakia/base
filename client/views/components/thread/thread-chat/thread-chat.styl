.chat-container
  display flex
  flex-direction column
  height 100%
  overflow hidden

.messages-container
  flex 1
  overflow-y auto
  padding 16px
  display flex
  flex-direction column
  scroll-behavior smooth

.thread-header
  display flex
  align-items center
  justify-content space-between
  padding 12px 16px
  background $color_surface_secondary
  border-bottom 1px solid $color_border

.thread-info
  display flex
  align-items center
  gap 8px
  font-size 12px
  color $color_text_secondary

.thread-status
  display flex
  align-items center
  gap 4px

  span
    display inline-block
    width 8px
    height 8px
    border-radius 50%
    margin-right 4px

    &.active
      background $color_success

    &.paused
      background $color_warning

    &.terminated
      background $color_danger

.thread-controls
  display flex
  align-items center
  gap 8px

.status-button
  display inline-flex
  align-items center
  background none
  border none
  padding 6px 12px
  font-size 12px
  border-radius 4px
  cursor pointer

  &:hover
    background $color_surface_hover

  &.pause
    color $color_warning

  &.resume
    color $color_success

  &.terminate
    color $color_danger

.thread-placeholder
  display flex
  flex-direction column
  align-items center
  justify-content center
  flex 1
  padding 24px
  color $color_text_secondary
  text-align center

.empty-message
  padding 16px
  text-align center
  color $color_text_secondary
  font-size 14px
  flex 1
  display flex
  align-items center
  justify-content center

.loading-indicator
  display flex
  align-items center
  justify-content center
  padding 12px

  .typing-indicator
    display flex
    align-items center
    gap 4px

    span
      width 8px
      height 8px
      background $color_text_secondary
      border-radius 50%
      animation pulse 1.5s infinite

      &:nth-child(1)
        animation-delay 0s

      &:nth-child(2)
        animation-delay 0.2s

      &:nth-child(3)
        animation-delay 0.4s

@keyframes pulse
  0%, 100%
    opacity 0.4
    transform scale(0.8)
  50%
    opacity 1
    transform scale(1) 