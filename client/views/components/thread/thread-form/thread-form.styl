@import '../../../../styles/mixins'

.form-container
  display flex
  flex-direction column
  padding $space_lg
  max-width 600px
  margin 0 auto

.form-title
  font-family $font_family_mono
  font-size $font_size_3xl
  font-weight $font_weight_semibold
  margin-bottom $space_lg

.form-group
  display flex
  flex-direction column
  margin-bottom $space_lg

.label
  font-family $font_family_mono
  font-size $font_size_base
  margin-bottom $space_sm
  font-weight $font_weight_medium
  color $color_text

.select
  form-control()
  appearance none

.textarea
  form-control()
  min-height 100px
  resize vertical

.submit-button
  button-primary()

.cancel-button
  button-base()

.button-group
  display flex
  gap $space_base
  margin-top $space_lg

.error-message
  color $color_danger
  font-family $font_family_mono
  font-size $font_size_base
  margin-top $space_sm

.loading
  display flex
  align-items center
  justify-content center
  padding $space_lg
  color $color_text_secondary
  font-family $font_family_mono

.help-text
  font-family $font_family_mono
  font-size $font_size_sm
  color $color_text_secondary
  margin-top $space_sm