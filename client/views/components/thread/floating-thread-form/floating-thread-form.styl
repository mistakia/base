@import '../../../../styles/mixins'

.floating-thread-form
  position relative
  width 100%
  max-width 1000px
  height auto
  background-color $color_surface
  border 1px solid $color_border
  border-radius $radius_base
  box-shadow $shadow_sm
  display flex
  flex-direction column
  overflow hidden
  transition all $transition_base
  padding $space_lg
  
  .form-header
    display flex
    justify-content space-between
    align-items center
    margin-bottom $space_base
    
    .context-chips
      display flex
      flex-wrap wrap
      gap $space_sm
      flex 1
      
      .context-chip
        display flex
        align-items center
        background-color $color_border_light
        border-radius $radius_sm
        padding $space_xs $space_sm
        font-family $font_family_mono
        font-size $font_size_xs
        
        .remove-chip
          background none
          border none
          color $color_text_secondary
          margin-left $space_xs
          cursor pointer
          font-size 16px
          padding 0 $space_xs
          
          &:hover
            color $color_text
    
    .close-button
      background none
      border none
      font-size 18px
      cursor pointer
      color $color_text_secondary
      padding 0 $space_xs
      
      &:hover
        color $color_text

  .message-area
    flex 1
    max-height 120px
    overflow-y auto
    min-height 40px
    margin-bottom $space_base
    
    .message-input
      width 100%
      height auto
      border none
      background-color transparent
      resize none
      font-family $font_family_mono
      font-size $font_size_base
      color $color_text
      outline none
      line-height 1.5
      
      &::placeholder
        color $color_text_secondary
      
      &:disabled
        opacity 0.5

  .form-footer
    display flex
    align-items center
    gap $space_base
    
    .model-selection
      display flex
      gap $space_sm
      flex-shrink 0
      
      .provider-select,
      .model-select
        form-control()
        font-size $font_size_sm
        width 160px
          
    .submit-button
      button-primary()
      padding $space_sm $space_base

  .error-message
    color $color_danger
    font-family $font_family_mono
    font-size $font_size_sm
    background-color $color_danger_subtle
    padding $space_sm
    border-radius $radius_sm
    margin-top $space_xs