// Local variables
$form_border_radius = 1em
$form_margin = 10px
$form_font_size_normal = 14px
$form_font_size_small = 12px

.floating-thread-form
  position relative
  width 100%
  max-width 1000px
  height auto
  background-color $color_surface
  border 1px solid rgba(13, 13, 13, 0.1)
  border-radius $form_border_radius
  box-shadow rgba(0, 0, 0, 0) 0px 0px 0px 0px, rgba(0, 0, 0, 0) 0px 0px 0px 0px, rgba(0, 0, 0, 0) 0px 0px 0px 0px, rgba(0, 0, 0, 0) 0px 0px 0px 0px, rgba(0, 0, 0, 0.1) 0px 10px 15px -3px, rgba(0, 0, 0, 0.1) 0px 4px 6px -4px
  display flex
  flex-direction column
  overflow hidden
  transition all 0.3s ease
  padding 1em 2em
  
  .form-header
    display flex
    justify-content space-between
    align-items center
    
    .context-chips
      display flex
      flex-wrap wrap
      gap 8px
      flex 1
      
      .context-chip
        display flex
        align-items center
        background-color $color_primary_disabled
        border-radius 16px
        padding 4px 10px
        font-size $form_font_size_small
        
        .remove-chip
          background none
          border none
          color $color_text_secondary
          margin-left 5px
          cursor pointer
          font-size 16px
          padding 0 2px
          
          &:hover
            color $color_text
    
    .close-button
      background none
      border none
      font-size 18px
      cursor pointer
      color $color_text_secondary
      padding 0 5px
      
      &:hover
        color $color_text

  .message-area
    flex 1
    max-height 120px
    overflow-y auto
    min-height 40px
    
    .message-input
      width 100%
      height auto
      border none
      background-color transparent
      resize none
      font-family inherit
      font-size $form_font_size_normal
      color $color_text
      outline none
      line-height 1.5
      
      &::placeholder
        color $color_text_secondary
      
      &:disabled
        opacity 0.5

  .form-footer
    display flex
    align-items center
    
    .model-selection
      display flex
      gap 10px
      flex-shrink 0
      
      .provider-select,
      .model-select
        padding 8px 10px
        border-radius 4px
        border 1px solid $color_border
        background-color $color_input_background
        font-size 13px
        color $color_text
        width 160px
        
        &:disabled
          background-color $color_input_disabled
          opacity 0.5
          
    .submit-button
      padding 8px 15px
      border-radius 4px
      border none
      background-color $color_primary
      color white
      font-weight 500
      cursor pointer
      margin-left 10px
      
      &:hover:not(:disabled)
        background-color $color_primary_hover
      
      &:disabled
        background-color $color_primary_disabled
        cursor not-allowed

  .error-message
    color $color_danger
    font-size $form_font_size_small
    background-color $color_danger_subtle
    margin-top 5px 