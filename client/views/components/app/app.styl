#app
  absolute top 0 left 0 bottom 0 right 0

.load__container
  display flex
  flex-direction column
  justify-content center
  align-items center
  width 100%
  height 100%

.app__container
  display flex
  height 100vh
  background $menu_background_color
  color $text_color

.app__sidebar
  background $menu_background_color
  min-width 220px
  max-width 260px
  display flex
  flex-direction column
  min-height 100vh

.app__main
  flex 1
  background $background_color
  color $text_color
  padding 0
  margin 1vh
  border-radius 2em
  overflow hidden
  overflow-y scroll
  border 1px solid $border_color
  transition margin 0.3s cubic-bezier(0.4,0,0.2,1), border-radius 0.3s cubic-bezier(0.4,0,0.2,1)
  position relative

.app__main--drawer-closed
  margin 0
  border-radius 0

.app__main--drawer-open
  margin 1vh
  border-radius 2em
  height 98vh
  margin-left 240px

.thread-form-wrapper
  position fixed
  bottom 24px
  left 0
  right 0
  display flex
  justify-content center
  z-index 1000

  // When drawer is closed, adjust for full width
  .app__main--drawer-closed &
    left 0

  // When drawer is open, adjust for drawer width
  .app__main--drawer-open &
    left 240px
