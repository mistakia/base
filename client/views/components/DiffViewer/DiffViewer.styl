@import '../../../styles/variables'

.diff-viewer
  width 100%
  overflow auto

  &--loading
    min-height 200px

  &__content
    width 100%

    // Ensure the diff fits the container - match ConflictResolver font size
    [data-diffs]
      width 100%
      font-size $font_size_xs
      line-height 1.4

    // Override any fixed widths from the library
    pre
      margin 0

    // Ensure split view panels are equal width
    .diffs-grid
      display grid
      grid-template-columns 1fr 1fr
