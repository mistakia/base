@import '@styles/variables'

.thread-lifecycle-indicator
  font-family $font_family_mono
  font-size $font_size_sm
  font-weight $font_weight_medium
  display inline-flex
  align-items center
  gap 0.4ch
  border-radius 0
  white-space nowrap
  letter-spacing 0

  &--footer
    padding 4px 8px

  &__spinner
    display inline-block
    width 1ch
    text-align center
