// Shared overlay variables (matches GlobalThreadInput)
$overlay-border-radius = 12px
$overlay-box-shadow = 0 1px 6px rgba(0, 0, 0, 0.06), 0 2px 12px rgba(0, 0, 0, 0.04)

.command-palette
  &__paper
    background-color var(--color-bg, #ffffff)
    border 1px solid var(--color-border, #e1e4e8)
    box-shadow $overlay-box-shadow
    border-radius $overlay-border-radius
    height 440px
    display flex
    flex-direction column

  &__input-container
    display flex
    align-items center
    flex-wrap wrap
    padding 6px 12px
    border-bottom 1px solid var(--color-border)
    gap 4px
    min-height 32px

  &__search-icon
    color var(--color-text-secondary)
    font-size 16px !important

  &__input
    flex 1
    min-width 120px
    background transparent
    border none
    outline none
    font-family var(--font-family-mono)
    font-size var(--font-size-sm)
    color var(--color-text)
    height 20px
    line-height 20px

    &::placeholder
      color var(--color-text-tertiary)

  &__loading
    color var(--color-text-secondary)

  &__result-count
    color var(--color-text-tertiary)
    font-size 10px
    flex-shrink 0

  &__results
    flex 1
    overflow-y auto

  &__section-header
    padding 6px 12px 4px
    font-size 10px
    font-weight 500
    text-transform uppercase
    color var(--color-text-tertiary)
    letter-spacing 0.5px

  &__result-item
    display flex
    align-items center
    height 20px
    padding 0 12px
    gap 8px
    cursor pointer
    font-family var(--font-family-mono)
    font-size var(--font-size-sm)
    line-height 20px

    &:hover
      background-color var(--color-surface-hover)

    &--selected
      background-color var(--color-primary)
      color var(--color-white)

      .command-palette__result-type
        color var(--color-white)
        opacity 0.7

      .command-palette__result-text
        color var(--color-white)

    &--selected:hover
      background-color var(--color-primary)
      color var(--color-white)

      .command-palette__result-type
        color var(--color-white)
        opacity 0.7

      .command-palette__result-text
        color var(--color-white)

      .command-palette__line-number
      .command-palette__context-line
      .command-palette__match-line
      .command-palette__similarity-score
      .command-palette__semantic-description
      .command-palette__semantic-chunk
        color rgba(255, 255, 255, 0.85)

  &__result-type
    color var(--color-text-tertiary)
    font-size 10px
    text-transform uppercase
    width 56px
    flex-shrink 0
    overflow hidden
    text-overflow ellipsis
    white-space nowrap

  &__result-text
    flex 1
    color var(--color-text)
    white-space nowrap
    overflow hidden
    text-overflow ellipsis
    min-width 0


  &__empty
    padding 12px
    text-align center
    color var(--color-text-secondary)
    font-size var(--font-size-sm)

  &__chip
    display inline-flex
    align-items center
    height 20px
    padding 0 6px
    border-radius 4px
    font-size 11px
    font-family var(--font-family-mono)
    flex-shrink 0
    gap 2px

    &--mode
      background-color rgba(0, 123, 255, 0.15)
      color var(--color-primary)

    &--operator
      background-color var(--color-surface-hover)
      border 1px solid var(--color-border)
      color var(--color-text-secondary)

    &--exclude
      background-color rgba(215, 58, 73, 0.10)
      color var(--color-error)

  &__chip-label
    white-space nowrap

  &__chip-remove
    display none
    cursor pointer
    font-size 14px
    line-height 1
    color var(--color-text-tertiary)
    margin-left 2px

    &:hover
      color var(--color-text)

  &__chip:hover &__chip-remove
    display inline

  &__mode-status
    font-size 10px
    color var(--color-text-tertiary)
    flex-shrink 0

  &__line-number
    color var(--color-text-tertiary)
    font-size var(--font-size-sm)
    flex-shrink 0

  &__similarity-score
    font-size 10px
    color var(--color-text-tertiary)
    flex-shrink 0
    margin-left auto

  &__content-header
    display flex
    align-items center
    gap 8px
    width 100%

  &__content-context
    padding 2px 12px 4px 68px
    font-family var(--font-family-mono)
    font-size 11px
    line-height 16px

  &__context-line
    color var(--color-text-tertiary)
    white-space nowrap
    overflow hidden
    text-overflow ellipsis

  &__match-line
    color var(--color-text)
    font-weight 500
    white-space nowrap
    overflow hidden
    text-overflow ellipsis

  &__semantic-header
    display flex
    align-items center
    gap 8px
    width 100%

  &__semantic-description
    padding 0 12px 2px 68px
    font-size 11px
    color var(--color-text-secondary)
    white-space nowrap
    overflow hidden
    text-overflow ellipsis

  &__semantic-chunk
    padding 0 12px 4px 68px
    font-size 11px
    color var(--color-text-tertiary)
    line-height 16px
    display -webkit-box
    -webkit-line-clamp 2
    -webkit-box-orient vertical
    overflow hidden

  &__result-item--content
  &__result-item--semantic
    height auto
    flex-direction column
    align-items flex-start
    padding 4px 12px
