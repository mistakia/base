.threads-table-loading
  display flex
  align-items center
  justify-content center
  padding 48px 24px
  color $color_text_secondary
  gap 12px
  
  .loading-spinner
    width 20px
    height 20px
    border 2px solid transparent
    border-top 2px solid $color_primary
    border-radius 50%
    animation spin 1s linear infinite
    
@keyframes spin
  0%
    transform rotate(0deg)
  100%
    transform rotate(360deg)

.threads-table-empty
  display flex
  align-items center
  justify-content center
  padding 48px 24px
  color $color_text_secondary

.threads-table-container
  width 100%
  max-width 1400px
  
  // Ensure table can use column widths properly
  .table
    width auto
    min-width fit-content
    
    // Left-align the working directory column content
    // Target by its distinctive width of 300px
    .cell[style*="width: 300px"]
      justify-content flex-start