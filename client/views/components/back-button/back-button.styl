.back-button
  display inline-flex
  align-items center
  gap 0.25rem
  padding 0.5rem 1rem
  background-color #f7fafc
  border 1px solid #e2e8f0
  border-radius 0.375rem
  color #4a5568
  text-decoration none
  font-size 0.875rem
  transition all 0.2s ease

  &:hover
    background-color #edf2f7
    border-color #cbd5e0
    color #2d3748
    text-decoration none