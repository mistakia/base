// ============================================================================
// Global Thread Input Component Styles
// ============================================================================
// Centered bottom input overlay with drop shadow

// Breakpoints
$breakpoint-desktop = 768px

// Spacing
$spacing-xs = 8px
$spacing-sm = 12px
$spacing-md = 16px

// Control heights
$control-height = 32px

// Border radius
$border-radius = 12px

// Overlay dimensions
$overlay-max-width = 720px
$overlay-margin = 24px

// ============================================================================
// Backdrop (transparent, just for click detection)
// ============================================================================

.global-thread-input-backdrop
  position: fixed
  top: 0
  left: 0
  right: 0
  bottom: 0
  display: flex
  justify-content: center
  align-items: flex-end
  padding: $overlay-margin
  padding-bottom: 48px
  box-sizing: border-box
  // Transparent backdrop - no overlay color
  background: transparent
  // Allow scroll events to pass through to the page
  pointer-events: none
  // Above bottom-bar (z-index: 100) and breadcrumb items (z-index: 20 on hover)
  z-index: 150

// ============================================================================
// Main Input Container
// ============================================================================

.global-thread-input
  position: relative
  width: 100%
  max-width: $overlay-max-width
  background: var(--color-bg, #ffffff)
  border-radius: $border-radius
  box-shadow: 0 1px 6px rgba(0, 0, 0, 0.06), 0 2px 12px rgba(0, 0, 0, 0.04)
  border: 1px solid var(--color-border, #e1e4e8)
  display: flex
  flex-direction: column
  // overflow: visible to allow autocomplete suggestions to extend above
  overflow: visible
  padding: $spacing-md
  // Re-enable pointer events for the input container
  pointer-events: auto

  // Mobile: more width, less margin
  @media (max-width: $breakpoint-desktop)
    max-width: calc(100% - $spacing-md * 2)
    margin: 0 $spacing-sm

  form
    width: 100%
    display: flex
    flex-direction: column

// ============================================================================
// Collapse Button (dismiss overlay)
// ============================================================================

.input-collapse-button
  position: absolute
  top: 6px
  right: 6px
  width: 24px
  height: 24px
  display: flex
  align-items: center
  justify-content: center
  cursor: pointer
  border-radius: 4px
  color: var(--color-text-tertiary, #6c757d)
  opacity: 0.5
  transition: opacity 0.15s ease

  &:hover
    opacity: 1

  .collapse-icon
    font-size: 18px

// ============================================================================
// Thread Context Indicator (shown when resuming a thread from outside thread page)
// ============================================================================

.thread-context-indicator
  display: flex
  align-items: center
  gap: 6px
  padding-bottom: $spacing-xs
  margin-bottom: $spacing-xs
  border-bottom: 1px solid var(--color-border-light, #f0f0f0)

  .thread-context-label
    color: var(--color-text-tertiary, #6c757d)
    font-size: 11px
    font-weight: 500
    text-transform: uppercase
    letter-spacing: 0.3px
    flex-shrink: 0

  .thread-context-title
    color: var(--color-text-secondary, #586069)
    font-size: 12px
    overflow: hidden
    text-overflow: ellipsis
    white-space: nowrap
    max-width: 100%

  &.permission-warning
    .thread-context-label
      color: var(--color-text-tertiary, #6c757d)
      text-transform: none
      letter-spacing: normal
      font-weight: 400

// ============================================================================
// Input Container with Autocomplete
// ============================================================================

.input-container-with-autocomplete
  position: relative
  width: 100%

// ============================================================================
// Text Input Field
// ============================================================================

.thread-input-field
  width: 100%

  .MuiInputBase-root
    padding: 0
    font-family: inherit
    font-size: 15px
    line-height: 1.5
    color: var(--color-text, #24292e)

    textarea
      padding: 0
      resize: none

      &::placeholder
        color: var(--color-text-tertiary, #6c757d)
        opacity: 1

// ============================================================================
// Bottom Row (within input container)
// ============================================================================

.input-bottom-row
  display: flex
  align-items: center
  justify-content: space-between
  margin-top: $spacing-sm
  padding-top: $spacing-xs
  border-top: 1px solid var(--color-border-light, #f0f0f0)
  gap: $spacing-xs

  .bottom-row-left
    display: flex
    align-items: center
    gap: $spacing-sm
    flex-wrap: wrap
    flex: 1
    min-width: 0

    .hint-text
      white-space: nowrap
      color: var(--color-text-tertiary, #6c757d)
      font-size: 11px

  .bottom-row-right
    display: flex
    align-items: center
    flex-shrink: 0
    gap: $spacing-xs

// ============================================================================
// Mode Toggle (segmented control)
// ============================================================================

.mode-toggle
  display: flex
  align-items: center
  gap: 0
  background: var(--color-surface, #ffffff)
  border-radius: 6px
  overflow: hidden
  cursor: pointer
  border: 1px solid var(--color-border, #ced4da)
  height: 28px

  .toggle-option
    padding: 4px $spacing-sm
    font-size: 11px
    font-weight: 500
    text-transform: uppercase
    letter-spacing: 0.5px
    color: var(--color-text-secondary, #6c757d)
    transition: all 0.2s ease
    white-space: nowrap
    height: 100%
    display: flex
    align-items: center
    justify-content: center

    &.active
      background: var(--color-breadcrumb-dark)
      color: var(--color-white, #ffffff)

    &:hover:not(.active)
      background: var(--color-surface-hover, #fafafa)

// ============================================================================
// Send Button
// ============================================================================

.send-button
  flex-shrink: 0
  min-width: auto
  width: $control-height
  height: $control-height
  padding: 0
  border-radius: 6px
  background-color: var(--color-breadcrumb-dark)

  &:hover
    background-color: var(--color-breadcrumb-dark)
    opacity: 0.9

  &.Mui-disabled
    background-color: var(--color-border-light)
    color: var(--color-text-tertiary)

  .loading-spinner
    color: var(--color-white, #ffffff)

  .send-icon
    font-size: 16px

// ============================================================================
// Microphone Button
// ============================================================================

.mic-button
  flex-shrink: 0
  min-width: auto
  width: 44px
  height: 44px
  padding: 0
  border-radius: 6px
  background-color: var(--color-surface, #ffffff)
  border: 1px solid var(--color-border, #ced4da)

  // Ensure 44x44px touch target on mobile
  @media (min-width: $breakpoint-desktop)
    width: $control-height
    height: $control-height

  &:hover
    background-color: var(--color-surface-hover, #fafafa)

  &.Mui-disabled
    background-color: var(--color-border-light)
    color: var(--color-text-tertiary)

  &.recording
    background-color: #dc3545
    border-color: #dc3545
    animation: pulse-recording 1.5s ease-in-out infinite

    .mic-icon
      color: var(--color-white, #ffffff)

  &.transcribing
    background-color: var(--color-border-light)

    .loading-spinner
      color: var(--color-text-secondary, #586069)

  .mic-icon
    font-size: 18px
    color: var(--color-text-secondary, #586069)

@keyframes pulse-recording
  0%, 100%
    opacity: 1
  50%
    opacity: 0.7

// ============================================================================
// Mobile Thread Input Trigger
// ============================================================================
// Slim bottom bar visible only on mobile. Tapping opens the full overlay.

.mobile-thread-input-trigger
  display: none

  @media (max-width: $breakpoint-desktop)
    display: flex
    align-items: center
    position: fixed
    left: $spacing-md
    right: $spacing-md
    bottom: $spacing-md
    height: 48px
    padding: 0 $spacing-md
    background: var(--color-bg, #ffffff)
    border: 1px solid var(--color-border, #e1e4e8)
    border-radius: $border-radius
    box-shadow: 0 1px 6px rgba(0, 0, 0, 0.06), 0 2px 12px rgba(0, 0, 0, 0.04)
    cursor: pointer
    z-index: 140
    // Below overlay (150), above page content

    &:active
      background: var(--color-surface-hover, #fafafa)

  .trigger-placeholder
    flex: 1
    font-size: 15px
    color: var(--color-text-tertiary, #6c757d)
    white-space: nowrap
    overflow: hidden
    text-overflow: ellipsis
    pointer-events: none

  .trigger-mic-icon
    flex-shrink: 0
    font-size: 20px
    color: var(--color-text-tertiary, #6c757d)
    margin-left: $spacing-xs
    pointer-events: none
