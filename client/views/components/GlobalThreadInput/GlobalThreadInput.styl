// ============================================================================
// Global Thread Input Component Styles
// ============================================================================
// Centered bottom input overlay with drop shadow

// Breakpoints
$breakpoint-desktop = 768px

// Spacing
$spacing-xs = 8px
$spacing-sm = 12px
$spacing-md = 16px

// Control heights
$control-height = 32px

// Border radius
$border-radius = 12px

// Overlay dimensions
$overlay-max-width = 720px
$overlay-margin = 24px

// ============================================================================
// Backdrop (transparent, just for click detection)
// ============================================================================

.global-thread-input-backdrop
  position: fixed
  top: 0
  left: 0
  right: 0
  bottom: 0
  display: flex
  justify-content: center
  align-items: flex-end
  padding: $overlay-margin
  box-sizing: border-box
  // Transparent backdrop - no overlay color
  background: transparent
  // Allow scroll events to pass through to the page
  pointer-events: none
  // Above ThreadSheet (z-index: 1200) and FloatingSessionsPanel (z-index: 1000)
  z-index: 1250

// ============================================================================
// Main Input Container
// ============================================================================

.global-thread-input
  position: relative
  width: 100%
  max-width: $overlay-max-width
  background: var(--color-bg, #ffffff)
  border-radius: $border-radius
  box-shadow: 0 1px 6px rgba(0, 0, 0, 0.06), 0 2px 12px rgba(0, 0, 0, 0.04)
  border: 1px solid var(--color-border, #e1e4e8)
  display: flex
  flex-direction: column
  // overflow: visible to allow autocomplete suggestions to extend above
  overflow: visible
  padding: $spacing-md
  // Re-enable pointer events for the input container
  pointer-events: auto

  // Mobile: more width, less margin
  @media (max-width: $breakpoint-desktop)
    max-width: calc(100% - $spacing-md * 2)
    margin: 0 $spacing-sm

  form
    width: 100%
    display: flex
    flex-direction: column

// ============================================================================
// Collapse Button (dismiss overlay)
// ============================================================================

.input-collapse-button
  position: absolute
  top: 6px
  right: 6px
  width: 24px
  height: 24px
  display: flex
  align-items: center
  justify-content: center
  cursor: pointer
  border-radius: 4px
  color: var(--color-text-tertiary, #6c757d)
  opacity: 0.5
  transition: opacity 0.15s ease

  &:hover
    opacity: 1

  .collapse-icon
    font-size: 18px

// ============================================================================
// Thread Context Indicator (shown when resuming a thread from outside thread page)
// ============================================================================

.thread-context-indicator
  display: flex
  align-items: center
  gap: 6px
  padding-bottom: $spacing-xs
  margin-bottom: $spacing-xs
  border-bottom: 1px solid var(--color-border-light, #f0f0f0)

  .thread-context-label
    color: var(--color-text-tertiary, #6c757d)
    font-size: 11px
    font-weight: 500
    text-transform: uppercase
    letter-spacing: 0.3px
    flex-shrink: 0

  .thread-context-title
    color: var(--color-text-secondary, #586069)
    font-size: 12px
    overflow: hidden
    text-overflow: ellipsis
    white-space: nowrap
    max-width: 100%

  &.permission-warning
    .thread-context-label
      color: var(--color-text-tertiary, #6c757d)
      text-transform: none
      letter-spacing: normal
      font-weight: 400

// ============================================================================
// Prompt History Panel
// ============================================================================

.prompt-history-panel
  max-height: 240px
  display: flex
  flex-direction: column
  border-bottom: 1px solid var(--color-border-light, #e9ecef)
  margin-bottom: $spacing-xs

.prompt-history-filter
  display: flex
  align-items: center
  gap: $spacing-xs
  padding-bottom: $spacing-xs

  .prompt-history-filter-input
    flex: 1
    min-width: 0
    border: 1px solid var(--color-border-light, #e9ecef)
    background: transparent
    padding: 4px $spacing-xs
    font-family: inherit
    font-size: 12px
    color: var(--color-text, #212529)
    outline: none

    &::placeholder
      color: var(--color-text-tertiary, #b0b0b0)

    &:focus
      border-color: var(--color-border, #ced4da)

  .prompt-history-clear-btn
    flex-shrink: 0
    background: transparent
    border: none
    cursor: pointer
    font-family: inherit
    font-size: 11px
    font-weight: 500
    text-transform: uppercase
    letter-spacing: 0.5px
    color: var(--color-text-secondary, #6c757d)
    padding: 4px $spacing-xs

    &:hover
      color: var(--color-text, #212529)

.prompt-history-list
  overflow-y: auto
  flex: 1
  min-height: 0

.prompt-history-entry
  display: flex
  align-items: center
  justify-content: space-between
  gap: $spacing-xs
  padding: 4px $spacing-xs
  cursor: pointer
  transition: background 0.15s ease

  &:hover,
  &.prompt-history-entry--selected
    background: var(--color-surface-hover, #fafafa)

  .prompt-history-entry-text
    flex: 1
    min-width: 0
    overflow: hidden
    text-overflow: ellipsis
    white-space: nowrap
    font-size: 13px
    color: var(--color-text, #212529)

  .prompt-history-timestamp
    flex-shrink: 0
    font-size: 11px
    color: var(--color-text-tertiary, #b0b0b0)

.prompt-history-empty
  padding: $spacing-sm $spacing-xs
  text-align: center
  font-size: 12px
  color: var(--color-text-secondary, #6c757d)

// ============================================================================
// Input Container with Autocomplete
// ============================================================================

.input-container-with-autocomplete
  position: relative
  width: 100%

// ============================================================================
// Text Input (contentEditable)
// ============================================================================

.thread-input-editable
  width: 100%
  min-height: 48px
  max-height: 240px
  overflow-y: auto
  padding: 0
  margin: 0
  border: none
  outline: none
  font-family: inherit
  font-size: 15px
  line-height: 1.5
  color: var(--color-text, #24292e)
  white-space: pre-wrap
  word-wrap: break-word
  -webkit-user-modify: read-write-plaintext-only
  -webkit-user-select: text
  user-select: text

  // Prevent iOS Safari auto-zoom on input focus (requires >= 16px)
  @media (max-width: $breakpoint-desktop)
    font-size: 16px

  // Placeholder via :empty pseudo-element
  &:empty::before
    content: attr(data-placeholder)
    color: var(--color-text-tertiary, #6c757d)
    pointer-events: none

  // Disabled state
  &[contenteditable="false"]
    opacity: 0.5
    cursor: not-allowed

// ============================================================================
// Bottom Row (within input container)
// ============================================================================

.input-bottom-row
  display: flex
  align-items: center
  justify-content: space-between
  margin-top: $spacing-sm
  padding-top: $spacing-xs
  border-top: 1px solid var(--color-border-light, #f0f0f0)
  gap: $spacing-xs

  .bottom-row-left
    display: flex
    align-items: center
    gap: $spacing-sm
    flex-wrap: wrap
    flex: 1
    min-width: 0

    .hint-text
      white-space: nowrap
      color: var(--color-text-tertiary, #6c757d)
      font-size: 11px

  .bottom-row-right
    display: flex
    align-items: center
    flex-shrink: 0
    gap: $spacing-xs

// ============================================================================
// Mode Toggle (segmented control)
// ============================================================================

.mode-toggle
  display: flex
  align-items: center
  gap: 0
  background: var(--color-surface, #ffffff)
  border-radius: 6px
  overflow: hidden
  cursor: pointer
  border: 1px solid var(--color-border, #ced4da)
  height: 28px

  .toggle-option
    padding: 4px $spacing-sm
    font-size: 11px
    font-weight: 500
    text-transform: uppercase
    letter-spacing: 0.5px
    color: var(--color-text-secondary, #6c757d)
    transition: all 0.2s ease
    white-space: nowrap
    height: 100%
    display: flex
    align-items: center
    justify-content: center

    &.active
      background: var(--color-breadcrumb-dark)
      color: var(--color-white, #ffffff)

    &:hover:not(.active)
      background: var(--color-surface-hover, #fafafa)

// ============================================================================
// Send Button
// ============================================================================

.send-button
  flex-shrink: 0
  min-width: auto
  width: $control-height
  height: $control-height
  padding: 0
  border-radius: 6px
  background-color: var(--color-breadcrumb-dark)

  &:hover
    background-color: var(--color-breadcrumb-dark)
    opacity: 0.9

  &.Mui-disabled
    background-color: var(--color-border-light)
    color: var(--color-text-tertiary)

  .loading-spinner
    color: var(--color-white, #ffffff)

  .send-icon
    font-size: 16px

// ============================================================================
// Microphone Button
// ============================================================================

.mic-button
  flex-shrink: 0
  min-width: auto
  width: 44px
  height: 44px
  padding: 0
  border-radius: 6px
  background-color: var(--color-surface, #ffffff)
  border: 1px solid var(--color-border, #ced4da)

  // Ensure 44x44px touch target on mobile
  @media (min-width: $breakpoint-desktop)
    width: $control-height
    height: $control-height

  &:hover
    background-color: var(--color-surface-hover, #fafafa)

  &.Mui-disabled
    background-color: var(--color-border-light)
    color: var(--color-text-tertiary)

  &.recording
    background-color: #dc3545
    border-color: #dc3545
    animation: pulse-recording 1.5s ease-in-out infinite

    .mic-icon
      color: var(--color-white, #ffffff)

  &.transcribing
    background-color: var(--color-border-light)

    .loading-spinner
      color: var(--color-text-secondary, #586069)

  .mic-icon
    font-size: 18px
    color: var(--color-text-secondary, #586069)

@keyframes pulse-recording
  0%, 100%
    opacity: 1
  50%
    opacity: 0.7

// ============================================================================
// Mobile Thread Input Trigger
// ============================================================================
// Slim bottom bar visible only on mobile. Tapping opens the full overlay.

.mobile-thread-input-trigger
  display: none

  @media (max-width: $breakpoint-desktop)
    display: flex
    align-items: center
    position: fixed
    left: $spacing-md
    right: $spacing-md
    bottom: "calc(%s + env(safe-area-inset-bottom, 0px))" % $spacing-md
    height: 48px
    padding: 0 $spacing-md
    background: var(--color-bg, #ffffff)
    border: 1px solid var(--color-border, #e1e4e8)
    border-radius: $border-radius
    box-shadow: 0 1px 6px rgba(0, 0, 0, 0.06), 0 2px 12px rgba(0, 0, 0, 0.04)
    cursor: pointer
    z-index: 140
    // Below overlay (150), above page content

    &:active
      background: var(--color-surface-hover, #fafafa)

  .trigger-placeholder
    flex: 1
    font-size: 15px
    color: var(--color-text-tertiary, #6c757d)
    white-space: nowrap
    overflow: hidden
    text-overflow: ellipsis
    pointer-events: none

  .trigger-mic-icon
    flex-shrink: 0
    font-size: 20px
    color: var(--color-text-tertiary, #6c757d)
    margin-left: $spacing-xs
    pointer-events: none
