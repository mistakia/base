// ============================================================================
// Working Directory Picker Component Styles
// ============================================================================

.working-directory-picker
  margin: 0

  // --------------------------------------------------------------------------
  // Directory Display Button (compact version)
  // --------------------------------------------------------------------------
  .directory-display
    // Layout
    display: flex
    align-items: center
    gap: 6px
    height: 28px
    padding: 4px 10px

    // Visual styling
    background: var(--color-surface-secondary, #f6f8fa)
    border: 1px solid var(--color-border-light, #e1e4e8)
    border-radius: 6px

    // Interaction
    cursor: pointer
    transition: all 0.2s ease

    &:hover
      border-color: var(--color-border, #d0d7de)
      background: var(--color-surface-hover, #fafbfc)

    // Content container with text overflow handling
    .directory-content
      flex: 1
      min-width: 0 // Required for text-overflow to work in flex container

      .picker-label
        display: none // Hide label in compact mode

      .directory-path
        // Typography
        font-weight: 500
        font-size: 11px
        line-height: 1.2
        color: var(--color-text-secondary, #586069)

        // Text overflow
        white-space: nowrap
        overflow: hidden
        text-overflow: ellipsis

    // Expandable arrow indicator
    .arrow-icon
      flex-shrink: 0
      font-size: 16px
      color: var(--color-icon, #586069)
      transition: transform 0.2s ease

      &.open
        transform: rotate(180deg)

// ============================================================================
// Dropdown Options Menu
// ============================================================================

.directory-options
  min-width: 250px
  max-width: 400px

  // Material-UI list overrides
  .MuiList-root
    padding: 4px

  .MuiListItemButton-root
    padding: 8px 12px
    border-radius: 4px
    max-height: 40px

    &.Mui-selected
      background-color: transparent

      &:hover
        background-color: var(--color-surface-hover, #fafbfc)

      .MuiListItemText-primary
        color: var(--color-primary, #1976d2)
        font-weight: 600

      .MuiListItemText-secondary
        color: var(--color-primary-dark, #1565c0)

    .MuiListItemText-secondary
      margin-top: 2px

      // Text overflow
      overflow: hidden
      text-overflow: ellipsis
      white-space: nowrap
