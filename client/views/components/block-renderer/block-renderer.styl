.block-renderer
  .block-item
    margin-bottom: 16px
    
    &.block-heading
      margin-bottom: 12px
      
      h1, h2, h3, h4, h5, h6
        margin: 0
        line-height: 1.3
    
    &.block-paragraph
      p
        margin: 0
        line-height: 1.6
    
    &.block-code
      margin-bottom: 20px
    
    &.block-blockquote
      blockquote
        margin: 0
        padding-left: 16px
        border-left: 4px solid #ddd
        color: #666
        font-style: italic
    
    &.block-list
      ul, ol
        margin: 0
        padding-left: 24px
        
      .task-item
        list-style: none
        margin-left: -24px
        padding-left: 24px
        
        input[type="checkbox"]
          margin-right: 8px
    
    &.block-image
      img
        max-width: 100%
        height: auto
      
      .image-caption
        margin-top: 8px
        font-size: 14px
        color: #666
        font-style: italic
    
    &.block-thematic-break
      hr
        border: none
        border-top: 1px solid #ddd
        margin: 24px 0
    
    &.block-table
      table
        width: 100%
        border-collapse: collapse
        
        td, th
          border: 1px solid #ddd
          padding: 8px 12px
          text-align: left
    
    &.block-redacted
      .redacted-content
        background: #000
        color: #000
        padding: 8px 12px
        border-radius: 4px
        display: inline-block
        min-width: 120px
        position: relative
        
        &:hover
          .redacted-label,
          .redacted-type,
          .redaction-reason
            color: #666
        
        .redacted-label
          font-weight: bold
          color: transparent
          
        .redacted-type
          font-size: 12px
          color: transparent
          margin-left: 8px
          
        .redaction-reason
          display: block
          font-size: 11px
          color: transparent
          margin-top: 4px
          font-style: italic
      
      &.block-heading .redacted-content
        min-height: 28px
        
      &.block-paragraph .redacted-content
        min-height: 20px
        
      &.block-code .redacted-content
        font-family: monospace
        min-height: 60px
    
    .list-item-redacted
      .redacted-content
        background: #000
        color: transparent
        padding: 4px 8px
        border-radius: 3px
        display: inline-block
        min-width: 100px
        
        &:hover .redacted-label
          color: #666
    
    .table-row-redacted
      .redacted-content
        background: #000
        color: transparent
        padding: 8px
        text-align: center
        
        &:hover .redacted-label
          color: #666
    
    .unknown-block
      padding: 8px 12px
      background: #f5f5f5
      border-radius: 4px
      border-left: 4px solid #ff9800
      
      strong
        color: #ff9800
        margin-right: 8px