// Floating Sessions Panel - persistent overlay
// Desktop: top-left below auth bar, Mobile: bottom-right above mobile input
// Shows active and pending sessions with lifecycle status

.floating-sessions-panel
  position: fixed
  z-index: 1000
  font-family: $font_family_mono
  font-size: $font_size_xs
  background: $color_surface
  border: 1px solid $color_border
  border-radius: $radius_base
  box-shadow: $shadow_md
  max-width: 600px
  min-width: 40px
  transition: min-width $transition_fast, max-width $transition_fast, box-shadow $transition_fast

  // Desktop: top-left below auth status bar
  top: 56px
  left: 16px

  @media (max-width: 768px)
    // Mobile: bottom-right above mobile thread input trigger
    // Trigger is 48px tall at bottom: calc(16px + safe-area), add 8px gap
    top: auto
    left: auto
    bottom: "calc(72px + env(safe-area-inset-bottom, 0px))"
    right: 16px
    max-width: none

  // Collapsed mode: pill with label groups
  &--collapsed
    min-width: 0
    max-width: 220px
    box-shadow: none

    .floating-sessions-panel__bar
      flex-direction: row
      justify-content: center
      align-items: center
      gap: $space_sm
      padding: $space_xs $space_sm

.floating-sessions-panel__bar
  display: flex
  align-items: center
  height: 40px
  gap: $space_sm
  padding: $space_sm $space_sm+2
  cursor: pointer
  user-select: none
  border-radius: $radius_base

  &:hover
    background: $color_surface_hover

// Expanded list: drops down on desktop, expands up on mobile
.floating-sessions-panel--list
  min-width: 240px
  border-color: $color_border

  @media (max-width: 768px)
    left: 8px
    display: flex
    flex-direction: column-reverse

.floating-sessions-panel__indicator
  width: 6px
  height: 6px
  border-radius: 50%
  background-color: $color_text_tertiary
  flex-shrink: 0

  &--active
    background-color: $color_success
    animation: pulse 1.5s ease-in-out infinite

.floating-sessions-panel__count
  color: $color_text_secondary
  font-size: $font_size_xs
  flex: 1

.floating-sessions-panel__dismiss
  display: flex
  align-items: center
  justify-content: center
  width: 20px
  height: 20px
  background: none
  border: 1px solid $color_border
  border-radius: $radius_sm
  color: $color_text_tertiary
  cursor: pointer
  padding: 0
  font-family: $font_family_mono
  font-size: $font_size_xs
  line-height: 1
  flex-shrink: 0

  &:hover
    color: $color_text
    border-color: $color_text_secondary
    background: $color_surface_hover

// List mode
.floating-sessions-panel__list
  max-height: 80vh
  overflow-y: auto
  padding: $space_sm

  // Reuse session-card styles in compact mode
  .session-card
    margin-bottom: $space_sm
    font-size: $font_size_xs

    &:last-child
      margin-bottom: 0

.floating-sessions-panel__empty
  padding: $space_base $space_sm
  color: $color_text_tertiary
  text-align: center

// Pending session items
.floating-sessions-panel__pending-item
  padding: $space_sm
  border-radius: $radius_sm
  background: rgba(0, 0, 0, 0.02)
  border: 1px solid $color_border_light
  margin-bottom: $space_xs

  &:last-child
    margin-bottom: 0

.floating-sessions-panel__pending-row
  display: flex
  align-items: center
  gap: $space_xs

.floating-sessions-panel__pending-status
  flex-shrink: 0

.floating-sessions-panel__status-queued
  color: $color_primary
  font-weight: $font_weight_medium

.floating-sessions-panel__status-failed
  color: $color_error
  font-weight: $font_weight_medium

.floating-sessions-panel__pending-prompt
  color: $color_text_secondary
  overflow: hidden
  text-overflow: ellipsis
  white-space: nowrap
  flex: 1

.floating-sessions-panel__pending-error
  display: flex
  align-items: center
  gap: $space_xs
  margin-top: 4px
  padding-top: 4px
  border-top: 1px solid $color_border_light

.floating-sessions-panel__error-text
  color: $color_text_tertiary
  flex: 1
  overflow: hidden
  text-overflow: ellipsis
  white-space: nowrap
  font-size: 10px

.floating-sessions-panel__retry-button
  background: none
  border: 1px solid $color_border
  border-radius: $radius_sm
  color: $color_primary
  cursor: pointer
  padding: 1px 6px
  font-family: $font_family_mono
  font-size: 10px
  flex-shrink: 0

  &:hover
    background: $color_surface_hover
    border-color: $color_primary

// Label group styles for collapsed bar
.floating-sessions-panel__label-group
  display: flex
  align-items: center
  gap: $space_xxs

.floating-sessions-panel__label-dot
  width: 6px
  height: 6px
  border-radius: 50%
  flex-shrink: 0

  &--active
    background-color: $color_success
    animation: pulse 1.5s ease-in-out infinite

  &--review
    background-color: $color_warning

.floating-sessions-panel__label-text
  font-size: $font_size_xs
  font-weight: $font_weight_semibold
  text-transform: uppercase
  letter-spacing: 0.5px
  color: $color_text_secondary
  flex-shrink: 0

.floating-sessions-panel__label-count
  font-family: $font_family_mono
  font-size: 10px
  color: $color_text_tertiary
  background: $color_surface_secondary
  padding: 1px 5px
  border-radius: $radius_sm
  flex-shrink: 0
