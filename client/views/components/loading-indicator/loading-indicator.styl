.loading-indicator
  display flex
  flex-direction column
  align-items center
  justify-content center
  padding 2rem
  gap 1rem

.loading-spinner
  width 2rem
  height 2rem
  border 2px solid #f3f3f3
  border-top 2px solid #3498db
  border-radius 50%
  animation spin 1s linear infinite

.loading-text
  color #666
  font-size 0.9rem

@keyframes spin
  0%
    transform rotate(0deg)
  100%
    transform rotate(360deg)