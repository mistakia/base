@import '@styles/variables'

.task-stats
  padding $space_sm
  width 100%

// Task flow chart
.task-flow-chart
  width 100%
  height 64px
  position relative
  cursor crosshair
  svg
    border-radius 8px
    display block

.task-flow-tooltip
  position absolute
  top -4px
  transform translateY(-100%)
  background #0d1117
  border 1px solid #30363d
  font-size 11px
  color #f0f6fc
  padding 4px 8px
  white-space nowrap
  pointer-events none
  z-index 10
  font-family inherit

.task-flow-tooltip-week
  color #9ca3af
  font-size 10px
  margin-bottom 1px

// Status bar
.task-status-bar-wrapper
  padding 0 $space_sm

.task-stats-status-bar
  display flex
  height 6px
  border-radius 3px
  overflow visible
  cursor pointer
  position relative

.task-stats-status-segment
  min-width 2px
  position relative
  &:first-child
    border-radius 3px 0 0 3px
  &:last-child
    border-radius 0 3px 3px 0

.task-stats-status-tooltip
  position absolute
  bottom 10px
  left 50%
  transform translateX(-50%)
  background #0d1117
  color #f0f6fc
  border 1px solid #30363d
  font-size 11px
  padding 2px 6px
  white-space nowrap
  pointer-events none
  z-index 10

.task-stats-status-legend
  display flex
  flex-wrap wrap
  gap $space_sm
  font-size 11px
  color $color_text_secondary
  padding-top $space_xs

.task-stats-legend-item
  display flex
  align-items center
  gap 3px

.task-stats-legend-dot
  width 6px
  height 6px
  border-radius 50%
  display inline-block
