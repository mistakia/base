@import '@styles/variables'

.task-stats
  padding $space_sm
  width 100%

// Period table
.task-stats-periods
  font-size 12px
  margin-bottom $space_sm

.task-stats-period-header
  display flex
  color $color_text_secondary
  font-size 10px
  text-transform uppercase
  letter-spacing 0.5px
  padding-bottom 2px

.task-stats-period-row
  display flex
  padding 1px 0

.task-stats-period-label
  width 36px
  color $color_text_secondary
  flex-shrink 0

.task-stats-period-col
  width 48px
  text-align right
  flex-shrink 0

// Sparklines
.task-stats-sparklines
  margin-bottom $space_sm

.task-stats-sparkline-row
  margin-bottom $space_xs

.task-stats-sparkline-label
  display block
  font-size 10px
  color $color_text_secondary
  text-transform uppercase
  letter-spacing 0.5px
  margin-bottom 1px

.task-stats-sparkline-container
  width 100%
  height 32px

// Status bar
.task-status-bar-wrapper
  padding 0 $space_sm

.task-stats-status-bar
  display flex
  height 6px
  border-radius 3px
  overflow visible
  cursor pointer
  position relative

.task-stats-status-segment
  min-width 2px
  position relative
  &:first-child
    border-radius 3px 0 0 3px
  &:last-child
    border-radius 0 3px 3px 0

.task-stats-status-tooltip
  position absolute
  bottom 10px
  left 50%
  transform translateX(-50%)
  background #0d1117
  color #f0f6fc
  border 1px solid #30363d
  font-size 11px
  padding 2px 6px
  white-space nowrap
  pointer-events none
  z-index 10

.task-stats-status-legend
  display flex
  flex-wrap wrap
  gap $space_sm
  font-size 11px
  color $color_text_secondary
  padding-top $space_xs

.task-stats-legend-item
  display flex
  align-items center
  gap 3px

.task-stats-legend-dot
  width 6px
  height 6px
  border-radius 50%
  display inline-block
