$assistant_message_border = hsl(210, 60%, 80%)

.assistant-message
  border-radius $radius_sm
  margin-bottom $space_xs
  background-color transparent
  border 1px solid $assistant_message_border
  padding $space_base
  width 100%
  overflow hidden
  transition border-color $transition_fast
  background-color $color_surface_secondary
  border-width 1px
  padding $space_base
  box-shadow $shadow_sm
  
  &--clickable
    cursor pointer
    
    &:hover
      border-color darken($assistant_message_border, 25%)

.assistant-message__content
  font-family $font_family_mono
  font-size $font_size_base
  line-height 1.5
  color $color_text
  white-space pre-wrap
  word-break break-word
  margin 0
    
  &--reasoning
    font-style italic
    color $color_text_secondary