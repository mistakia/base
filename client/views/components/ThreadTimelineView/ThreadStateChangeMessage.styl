.thread-state-change
  display: flex
  align-items: flex-start
  gap: 8px
  padding: 8px 12px
  border-radius: 6px
  font-family: $font_family_mono
  font-size: $font_size_xs
  line-height: 1.4
  width: 100%
  background-color: rgba(156, 39, 176, 0.08)
  border: 1px solid rgba(156, 39, 176, 0.2)
  color: $color_text_secondary

.thread-state-change__icon
  flex-shrink: 0
  margin-top: 2px
  color: #9c27b0

.thread-state-change__content
  display: flex
  flex-direction: column
  gap: 4px
  flex: 1
  min-width: 0

.thread-state-change__label
  white-space: pre-wrap
  word-break: break-word

.thread-state-change__state
  font-weight: 600
  color: $color_text_primary

.thread-state-change__reason
  font-size: $font_size_xxs
  color: $color_text_tertiary
  font-style: italic
