.thread-state-change
  display: flex
  align-items: center
  gap: 12px
  padding: 6px 10px
  border-radius: 4px
  font-family: $font_family_mono
  font-size: $font_size_xs
  line-height: 1.4
  width: 100%
  background-color: rgba($color_user_message_bg, 0.5)
  color: $color_text_tertiary

.thread-state-change__transition
  white-space: nowrap

.thread-state-change__reason
  color: $color_text_tertiary
  font-style: italic
