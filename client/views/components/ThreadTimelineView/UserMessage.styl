$user_message_bg = hsl(32, 21.30%, 94.00%)

.user-message
  background-color: $user_message_bg
  border-radius: $radius_sm
  padding: $space_base
  margin-bottom: $space_xs
  position: relative
  width: 100%

  font-family: $font_family_mono
  font-size: $font_size_base
  line-height: 1.5
  color: $color_text
  white-space: pre-wrap
  word-break: break-word
  overflow: hidden

.user-message__header
  position: absolute
  top: 8px
  right: 8px
  z-index: 1
  display: flex
  align-items: center
  gap: 4px

.user-message__chip
  text-transform: uppercase
  background: darken($user_message_bg, 6%)
  border-color: darken($user_message_bg, 6%)

  &:hover
    background: darken($user_message_bg, 6%)
    border-color: darken($user_message_bg, 6%)

.user-message__content
  margin-bottom: 0
  padding-top: $space_lg

  &--truncated
    margin-bottom: $space_sm

.user-message__command
  display: flex
  align-items: baseline
  gap: $space_xs
  font-family: $font_family_mono
  font-size: $font_size_base
  color: $color_text
  white-space: normal
  word-break: break-word

.user-message__command-prompt
  color: $color_text_secondary

.user-message__command-name
  font-weight: $font_weight_medium
  color: $color_text

.user-message__command-args
  color: $color_text_secondary
  margin-left: $space_lg

.user-message__command-message
  width: 100%
  font-size: $font_size_sm
  color: $color_text_secondary
  margin-top: $space_xs
  display: flex
  gap: $space_xs
  align-items: flex-start

.user-message__command-prefix
  color: $color_text_secondary
  flex-shrink: 0

.user-message__command-message-text
  white-space: normal
  word-break: break-word