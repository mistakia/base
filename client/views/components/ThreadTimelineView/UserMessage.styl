.user-message
  background-color: $color_user_message_bg
  border-radius: $radius_base
  padding: $space_base
  position: relative
  width: 100%

  font-family: $font_family_mono
  font-size: $font_size_base
  line-height: 1.5
  color: $color_text
  white-space: pre-wrap
  word-break: break-word
  overflow: hidden

.user-message__header
  position: absolute
  top: 8px
  right: 8px
  z-index: 1
  display: flex
  align-items: center
  gap: 4px

.user-message__header .MuiIconButton-root
  opacity: 0
  transition: opacity $transition_fast

.user-message:hover .user-message__header .MuiIconButton-root
  opacity: 1

.user-message__chip
  text-transform: uppercase
  font-size: $font_size_xs
  font-weight: $font_weight_bold
  letter-spacing: 0.06em
  padding: 4px 10px
  color: $color_white
  background: $color_user_chip_bg
  border-color: $color_user_chip_bg

  &:hover
    color: $color_white
    background: darken($color_user_chip_bg, 5%)
    border-color: darken($color_user_chip_bg, 5%)

.user-message__content
  margin-bottom: 0
  padding-top: $space_lg

  &--truncated
    margin-bottom: $space_sm

.user-message__command
  display: flex
  align-items: baseline
  gap: $space_xs
  font-family: $font_family_mono
  font-size: $font_size_base
  color: $color_text
  white-space: normal
  word-break: break-word

.user-message__command-prompt
  color: $color_text

.user-message__command-name
  font-weight: $font_weight_medium
  color: $color_text

.user-message__command-args
  color: $color_text
  margin-left: $space_lg

.user-message__command-message
  width: 100%
  font-size: $font_size_base
  color: $color_text
  margin-top: $space_xs
  display: flex
  gap: $space_xs
  align-items: flex-start

.user-message__command-prefix
  color: $color_text
  flex-shrink: 0

.user-message__command-message-text
  white-space: normal
  word-break: break-word