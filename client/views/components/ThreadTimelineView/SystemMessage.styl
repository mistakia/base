.system-message
  display: flex
  align-items: flex-start
  gap: 8px
  padding: 8px 12px
  border-radius: 6px
  font-family: $font_family_mono
  font-size: $font_size_xs
  line-height: 1.4
  white-space: pre-wrap
  word-break: break-word
  overflow: hidden
  width: 100%

  &--clickable
    cursor: pointer
    transition: background-color $transition_fast, border-color $transition_fast

    &:hover
      filter: brightness(1.1)

  // Severity-based styles
  &--warning
    background-color: rgba(255, 152, 0, 0.1)
    border: 1px solid rgba(255, 152, 0, 0.3)
    color: #e65100

    .system-message__icon
      color: #ff9800

  &--error
    background-color: rgba(244, 67, 54, 0.1)
    border: 1px solid rgba(244, 67, 54, 0.3)
    color: #c62828

    .system-message__icon
      color: #f44336

  &--interrupt
    background-color: rgba(158, 158, 158, 0.1)
    border: 1px solid rgba(158, 158, 158, 0.3)
    color: $color_text_secondary

    .system-message__icon
      color: #9e9e9e

  &--info
    background-color: rgba(33, 150, 243, 0.1)
    border: 1px solid rgba(33, 150, 243, 0.3)
    color: #1565c0

    .system-message__icon
      color: #2196f3

.system-message__icon
  flex-shrink: 0
  margin-top: 2px

.system-message__content
  flex: 1
  min-width: 0

.system-message__text
  white-space: pre-wrap
  word-break: break-word
  line-height: 1.4

  // Style ANSI rendered content
  span
    // Ensure ANSI styled spans maintain proper spacing and wrapping
    white-space: pre-wrap
    word-break: inherit

.system-message__expand-hint
  flex-shrink: 0
  font-size: $font_size_xxs
  color: $color_text_tertiary
  opacity: 0.7
  margin-left: auto
  align-self: center