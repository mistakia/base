.system-message
  display: flex
  align-items: flex-start
  gap: 8px
  padding: 8px 12px
  border-radius: 6px
  font-family: $font_family_mono
  font-size: $font_size_xs
  line-height: 1.4
  white-space: pre-wrap
  word-break: break-word
  overflow: hidden
  width: 100%

  &--clickable
    cursor: pointer
    transition: background-color $transition_fast, border-color $transition_fast

    &:hover
      filter: brightness(1.1)

  // Severity-based styles
  &--warning
    background-color: rgba($color_warning, 0.1)
    color: darken($color_warning, 15%)

    .system-message__icon
      color: $color_warning

  &--error
    background-color: rgba($color_error, 0.1)
    color: darken($color_error, 10%)

    .system-message__icon
      color: $color_error

  &--interrupt
    background-color: rgba($color_text_secondary, 0.1)
    color: $color_text_secondary

    .system-message__icon
      color: $color_text_secondary

  &--info
    background-color: rgba($color_info, 0.1)
    color: darken($color_info, 10%)

    .system-message__icon
      color: $color_info

.system-message__icon
  flex-shrink: 0
  margin-top: 1px
  font-size: 14px

.system-message__content
  flex: 1
  min-width: 0

.system-message__text
  white-space: pre-wrap
  word-break: break-word
  line-height: 1.4

  // Style ANSI rendered content
  span
    // Ensure ANSI styled spans maintain proper spacing and wrapping
    white-space: pre-wrap
    word-break: inherit

.system-message__expand-hint
  flex-shrink: 0
  font-size: $font_size_xxs
  color: $color_text_tertiary
  opacity: 0.7
  margin-left: auto
  align-self: center