.thinking-message
  margin-bottom $space_xs
  padding $space_xs 0

.thinking-message__toggle
  background none
  border none
  font-family $font_family_mono
  font-size $font_size_sm
  color $color_text_secondary
  cursor pointer
  padding 0
  margin 0

  &:hover
    color $color_text

  &:focus
    outline none

.thinking-message__content
  font-family $font_family_mono
  font-size $font_size_base
  line-height 1.5
  color $color_text_secondary
  font-style italic
  white-space pre-wrap
  word-break break-word
  margin $space_base 0 0 0
  padding-left $space_base


