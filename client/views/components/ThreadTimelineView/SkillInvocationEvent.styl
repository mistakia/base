.skill-invocation__user-text
  margin-bottom: $space_sm
  white-space: normal
  word-break: normal
  color: $color_text

.skill-invocation__skills
  display: flex
  flex-direction: column
  gap: $space_xs

.skill-invocation__skill-header
  display: flex
  align-items: center
  gap: $space_xs

.skill-invocation__skill-chip
  font-family: $font_family_mono
  font-size: $font_size_base
  font-weight: $font_weight_medium
  color: $color_primary
  cursor: pointer

  &:hover
    text-decoration: underline

.skill-invocation__skill-link
  font-size: $font_size_xs
  color: $color_text_secondary
  text-decoration: none
  white-space: nowrap
  overflow: hidden
  text-overflow: ellipsis
  max-width: 300px

  &:hover
    color: $color_primary
    text-decoration: underline

.skill-invocation__expand-toggle
  margin-left: auto

.skill-invocation__expansion
  margin-top: $space_xs
  padding: $space_sm
  font-size: $font_size_sm
  color: $color_text_secondary
  white-space: normal
  word-break: break-word
  overflow: hidden
