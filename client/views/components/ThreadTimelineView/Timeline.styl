:root
  // Shared accent color for timeline elements (used in TimelineList and SubThreadTool)
  --timeline-accent: var(--color-border)

.timeline-list
  display: flex
  flex-direction: column
  gap: $space_sm

.timeline-scroll-button
  position: sticky
  bottom: var(--space-lg)
  left: 0
  right: 0
  margin: 0 auto
  width: 28px
  height: 28px
  border-radius: 50%
  background-color: var(--color-bg, #ffffff)
  color: var(--color-text-secondary)
  display: flex
  align-items: center
  justify-content: center
  cursor: pointer
  box-shadow: 0 1px 6px rgba(0, 0, 0, 0.06), 0 2px 12px rgba(0, 0, 0, 0.04)
  transition: all var(--transition-base, 0.2s ease)
  z-index: 1000
  border: 1px solid var(--color-border-light, #e1e4e8)
  outline: none

  &:hover
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1), 0 4px 6px rgba(0, 0, 0, 0.06)
    transform: translateY(-2px)

  &:active
    transform: translateY(0)

  &:focus
    outline: 2px solid var(--color-border)
    outline-offset: 2px

  svg
    width: 16px
    height: 16px
    display: block

