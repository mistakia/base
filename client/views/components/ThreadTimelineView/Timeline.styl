:root
  // Shared accent color for timeline elements (used in TimelineList and SubThreadTool)
  --timeline-accent: var(--color-border)

.timeline-list
  display: flex
  flex-direction: column
  gap: $space_sm

.timeline-scroll-button
  position: sticky
  bottom: var(--space-lg)
  left: 0
  right: 0
  margin: 0 auto
  width: 28px
  height: 28px
  border-radius: 50%
  background-color: var(--color-bg, #ffffff)
  color: var(--color-text-secondary)
  display: flex
  align-items: center
  justify-content: center
  cursor: pointer
  box-shadow: 0 1px 6px rgba(0, 0, 0, 0.06), 0 2px 12px rgba(0, 0, 0, 0.04)
  transition: all var(--transition-base, 0.2s ease)
  z-index: 1000
  border: 1px solid var(--color-border-light, #e1e4e8)
  outline: none

  &:hover
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1), 0 4px 6px rgba(0, 0, 0, 0.06)
    transform: translateY(-2px)

  &:active
    transform: translateY(0)

  &:focus
    outline: 2px solid var(--color-border)
    outline-offset: 2px

  svg
    width: 16px
    height: 16px
    display: block

// ============================================================================
// File Browser Toggle & Container (in right column)
// ============================================================================

.file-browser-toggle-button
  // Minimalist, brutalist-style button matching codebase patterns
  background: none
  border: 1px solid var(--color-border)
  border-radius: var(--radius-base)
  color: var(--color-text-secondary)
  font-size: var(--font-size-sm)
  font-family: var(--font-family-mono)
  font-weight: 500
  cursor: pointer
  padding: var(--space-sm) var(--space-base)
  text-decoration: none
  letter-spacing: 0.5px
  text-transform: uppercase
  user-select: none
  transition: all var(--transition-fast, 0.15s ease)
  width: auto
  white-space: nowrap

  // Subtle interaction states
  &:hover
    // Note: --color-border-hover doesn't exist in design system, using fallback
    border-color: var(--color-border-hover, #959da5)
    background: var(--color-surface-hover)
    color: var(--color-text)

  &:active
    background: var(--color-surface)

  &:focus
    outline: none

  // Remove browser button styles
  -webkit-appearance: none
  -moz-appearance: none
  appearance: none

.file-browser-container
  width: 100%
  max-width: 100%
  background: var(--color-surface)
  padding: var(--space-base)
  overflow: hidden
  margin-top: var(--space-base)

  // Ensure file browser respects container bounds
  .filesystem-browser-container
    height: auto
    max-height: calc(100vh - 300px)
    overflow-y: auto