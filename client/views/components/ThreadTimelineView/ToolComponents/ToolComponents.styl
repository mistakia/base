// Tool Components Styling
// Extends the base Material-UI theme with tool-specific enhancements
@import '@styles/variables'

// Code highlighting improvements
.tool-code-block
  font-family: 'Monaco', 'Menlo', 'Ubuntu Mono', monospace !important
  font-size: 11px !important
  line-height: 1.4 !important
  
  // Syntax highlighting colors (basic) - GitHub light theme
  .keyword
    color: $color_error
    font-weight: bold

  .string
    color: #032f62

  .number
    color: $color_info

  .comment
    color: $color_text_secondary
    font-style: italic

  .function
    color: #6f42c1

// Diff view styling for Edit tools
.diff-container
  display: flex
  border: 1px solid $color_code_border
  border-radius: $radius_base
  overflow: hidden

  .diff-removed
    background-color: $color_diff_removed_bg
    border-right: 1px solid $color_code_border

    &::before
      content: '- '
      color: $color_error
      font-weight: bold

  .diff-added
    background-color: $color_diff_added_bg

    &::before
      content: '+ '
      color: $color_success
      font-weight: bold

// Terminal styles moved to components/terminal.styl
@import '@styles/components/terminal'

// Database table styling enhancements
.db-table-container
  .MuiTableCell-head
    background-color: var(--color-code-bg) !important
    font-weight: 600 !important
    font-size: 11px !important
    font-family: 'Monaco', 'Menlo', monospace !important
  
  .MuiTableCell-body
    font-size: 11px !important
    font-family: 'Monaco', 'Menlo', monospace !important
    
    &.null-value
      font-style: italic !important
      color: $color_text_secondary !important

// Search result highlighting

// Responsive design adjustments
@media (max-width: 768px)
  .diff-container
    flex-direction: column
    
    .diff-removed
      border-right: none
      border-bottom: 1px solid $color_code_border

// Dark theme support (if needed)
@media (prefers-color-scheme: dark)
  .tool-code-block
    background-color: #161b22 !important
    color: #f0f6fc !important
    
    .keyword
      color: #ff7b72
    
    .string
      color: #a5d6ff
    
    .number
      color: #79c0ff
    
    .comment
      color: #8b949e
    
    .function
      color: #d2a8ff
  
  .search-highlight
    background-color: #ffd33d !important
    color: #1b1f23 !important