// Tool Components Styling
// Extends the base Material-UI theme with tool-specific enhancements

// Color palette for tool types
.tool-filesystem
  border-left-color: #1976d2 !important // primary.main
  background-color: rgba(25, 118, 210, 0.08) !important // primary.light with opacity

.tool-execution
  border-left-color: #9c27b0 !important // secondary.main  
  background-color: rgba(156, 39, 176, 0.08) !important // secondary.light with opacity

.tool-search
  border-left-color: #0288d1 !important // info.main
  background-color: rgba(2, 136, 209, 0.08) !important // info.light with opacity

.tool-management
  border-left-color: #ed6c02 !important // warning.main
  background-color: rgba(237, 108, 2, 0.08) !important // warning.light with opacity

.tool-mcp
  border-left-color: #9c27b0 !important // secondary.main
  background-color: rgba(156, 39, 176, 0.08) !important // secondary.light with opacity

// Visual connection between tool calls and results
.tool-pair-connection
  position: relative
  
  &::before
    content: ''
    position: absolute
    left: -8px
    top: 0
    bottom: 0
    width: 2px
    background-color: rgba(0, 0, 0, 0.12)
    border-radius: 1px

// Code highlighting improvements
.tool-code-block
  font-family: 'Monaco', 'Menlo', 'Ubuntu Mono', monospace !important
  font-size: 11px !important
  line-height: 1.4 !important
  
  // Syntax highlighting colors (basic)
  .keyword
    color: #d73a49
    font-weight: bold
  
  .string
    color: #032f62
  
  .number
    color: #005cc5
  
  .comment
    color: #6a737d
    font-style: italic
  
  .function
    color: #6f42c1

// Diff view styling for Edit tools
.diff-container
  display: flex
  border: 1px solid #e1e4e8
  border-radius: 4px
  overflow: hidden
  
  .diff-removed
    background-color: #ffeef0
    border-right: 1px solid #e1e4e8
    
    &::before
      content: '- '
      color: #d73a49
      font-weight: bold
  
  .diff-added
    background-color: #e6ffed
    
    &::before
      content: '+ '
      color: #28a745
      font-weight: bold

// Terminal-style output for Bash tools
.terminal-output
  background-color: #0d1117 !important
  color: #f0f6fc !important
  font-family: 'Monaco', 'Menlo', 'Ubuntu Mono', monospace !important
  
  .terminal-prompt
    color: #58a6ff !important
    font-weight: bold !important
  
  .terminal-success
    color: #56d364 !important
  
  .terminal-error
    color: #f85149 !important

// Database table styling enhancements
.db-table-container
  .MuiTableCell-head
    background-color: var(--color-code-bg) !important
    font-weight: 600 !important
    font-size: 11px !important
    font-family: 'Monaco', 'Menlo', monospace !important
  
  .MuiTableCell-body
    font-size: 11px !important
    font-family: 'Monaco', 'Menlo', monospace !important
    
    &.null-value
      font-style: italic !important
      color: #6a737d !important

// Search result highlighting

// Responsive design adjustments
@media (max-width: 768px)
  .tool-pair-connection
    &::before
      display: none
  
  .diff-container
    flex-direction: column
    
    .diff-removed
      border-right: none
      border-bottom: 1px solid #e1e4e8

// Dark theme support (if needed)
@media (prefers-color-scheme: dark)
  .tool-code-block
    background-color: #161b22 !important
    color: #f0f6fc !important
    
    .keyword
      color: #ff7b72
    
    .string
      color: #a5d6ff
    
    .number
      color: #79c0ff
    
    .comment
      color: #8b949e
    
    .function
      color: #d2a8ff
  
  .search-highlight
    background-color: #ffd33d !important
    color: #1b1f23 !important