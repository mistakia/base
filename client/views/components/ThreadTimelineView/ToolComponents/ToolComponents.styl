// Tool Components Styling
// Extends the base Material-UI theme with tool-specific enhancements
@import '../../../../styles/variables'

// Color palette for tool types
.tool-filesystem
  border-left-color: $color_tool_filesystem !important
  background-color: rgba(25, 118, 210, 0.08) !important

.tool-execution
  border-left-color: $color_tool_execution !important
  background-color: rgba(156, 39, 176, 0.08) !important

.tool-search
  border-left-color: $color_tool_search !important
  background-color: rgba(2, 136, 209, 0.08) !important

.tool-management
  border-left-color: $color_tool_management !important
  background-color: rgba(237, 108, 2, 0.08) !important

.tool-mcp
  border-left-color: $color_tool_mcp !important
  background-color: rgba(156, 39, 176, 0.08) !important

// Visual connection between tool calls and results
.tool-pair-connection
  position: relative
  
  &::before
    content: ''
    position: absolute
    left: -8px
    top: 0
    bottom: 0
    width: 2px
    background-color: rgba(0, 0, 0, 0.12)
    border-radius: 1px

// Code highlighting improvements
.tool-code-block
  font-family: 'Monaco', 'Menlo', 'Ubuntu Mono', monospace !important
  font-size: 11px !important
  line-height: 1.4 !important
  
  // Syntax highlighting colors (basic) - GitHub light theme
  .keyword
    color: $color_error
    font-weight: bold

  .string
    color: #032f62

  .number
    color: $color_info

  .comment
    color: $color_text_secondary
    font-style: italic

  .function
    color: #6f42c1

// Diff view styling for Edit tools
.diff-container
  display: flex
  border: 1px solid $color_code_border
  border-radius: $radius_base
  overflow: hidden

  .diff-removed
    background-color: $color_diff_removed_bg
    border-right: 1px solid $color_code_border

    &::before
      content: '- '
      color: $color_error
      font-weight: bold

  .diff-added
    background-color: $color_diff_added_bg

    &::before
      content: '+ '
      color: $color_success
      font-weight: bold

// Terminal-style output for Bash tools
.terminal-output
  background-color: $color_terminal_bg !important
  color: $color_terminal_text !important
  font-family: $font_family_mono !important

  .terminal-prompt
    color: $color_terminal_prompt !important
    font-weight: bold !important

  .terminal-success
    color: $color_terminal_success !important

  .terminal-error
    color: $color_terminal_error !important

// Database table styling enhancements
.db-table-container
  .MuiTableCell-head
    background-color: var(--color-code-bg) !important
    font-weight: 600 !important
    font-size: 11px !important
    font-family: 'Monaco', 'Menlo', monospace !important
  
  .MuiTableCell-body
    font-size: 11px !important
    font-family: 'Monaco', 'Menlo', monospace !important
    
    &.null-value
      font-style: italic !important
      color: $color_text_secondary !important

// Search result highlighting

// Responsive design adjustments
@media (max-width: 768px)
  .tool-pair-connection
    &::before
      display: none
  
  .diff-container
    flex-direction: column
    
    .diff-removed
      border-right: none
      border-bottom: 1px solid $color_code_border

// Dark theme support (if needed)
@media (prefers-color-scheme: dark)
  .tool-code-block
    background-color: #161b22 !important
    color: #f0f6fc !important
    
    .keyword
      color: #ff7b72
    
    .string
      color: #a5d6ff
    
    .number
      color: #79c0ff
    
    .comment
      color: #8b949e
    
    .function
      color: #d2a8ff
  
  .search-highlight
    background-color: #ffd33d !important
    color: #1b1f23 !important