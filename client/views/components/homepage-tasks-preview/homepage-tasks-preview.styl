@import '../../../styles/mixins'

.homepage-tasks-preview-container
  margin $space_lg 0
  
  .homepage-tasks-preview-header
    display flex
    justify-content space-between
    align-items center
    margin-bottom $space_base
    
    h2
      margin 0
      font-family $font_family_mono
      font-size $font_size_xl
      font-weight $font_weight_semibold
    
    .view-all-link
      text-decoration none
      color $color_link
      font-family $font_family_mono
      font-size $font_size_sm
      
      &:hover
        text-decoration underline
  
  .homepage-tasks-preview-list
    .task-preview-item
      list-item()
      padding $space_base
      
      &:last-child
        border-bottom none

      .task-preview-title
        font-family $font_family_mono
        font-size $font_size_lg
        font-weight $font_weight_semibold
        margin-bottom $space_sm
        color $color_text

      .task-preview-status,
      .task-preview-priority
        status-badge()
        margin-right $space_base
        margin-bottom $space_sm

      .task-preview-status
        background-color $color_success_subtle
        color $color_success

      .task-preview-priority
        background-color $color_warning_subtle
        color $color_warning

      .task-preview-description
        font-family $font_family_mono
        font-size $font_size_base
        color $color_text_secondary
        margin-top $space_sm
        display -webkit-box
        -webkit-line-clamp 2
        -webkit-box-orient vertical
        overflow hidden
    
    .no-tasks
      empty-state()
      font-style italic

.task-link
  display block
  text-decoration none
  color inherit
  margin-bottom $space_base
  transition opacity $transition_fast

  &:hover
    opacity 0.9