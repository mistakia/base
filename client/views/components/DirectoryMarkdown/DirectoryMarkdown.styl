// Directory markdown viewer container
.directory-markdown-container
  max-width 600px
  margin-bottom: $space_xl
  background-color: rgba($color_surface, 0.5)
  
  // Responsive adjustments
  @media (max-width: 768px)
    margin-bottom: $space_lg
    padding: $space_base

.directory-markdown-loading,
.directory-markdown-error
  padding: 10px
  margin: 10px 0
  border-radius: 4px
  
.directory-markdown-loading
  background-color: #f0f0f0
  color: #666
  
.directory-markdown-error
  background-color: #fee
  color: #c00
  border: 1px solid #fcc