// DirectoryMarkdown component styles - moved from DirectoryPage
.directory-markdown-container
  margin-bottom: 20px
  
.directory-markdown-loading,
.directory-markdown-error
  padding: 10px
  margin: 10px 0
  border-radius: 4px
  
.directory-markdown-loading
  background-color: #f0f0f0
  color: #666
  
.directory-markdown-error
  background-color: #fee
  color: #c00
  border: 1px solid #fcc