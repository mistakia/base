.user-root-container
  padding 30px 20px
  max-width 1000px
  margin 0 auto

.user-root-header
  margin-bottom 30px
  
  h1
    color $color_text
    font-size 2rem
    margin-bottom 12px
    font-weight 300

.user-root-public-notice
  background-color $color_warning_subtle
  color $color_text_secondary
  padding 12px 16px
  border-radius 6px
  border-left 4px solid $color_warning
  font-size 0.9rem
  
  a
    color $color_link
    text-decoration none
    
    &:hover
      text-decoration underline

.user-root-loading
  color $color_text_secondary
  text-align center
  padding 40px 20px
  font-style italic

.user-root-not-found
  text-align center
  padding 40px 20px
  
  h2
    color $color_text
    margin-bottom 16px
    font-weight 400
    
  p
    color $color_text_secondary
    line-height 1.6

.user-root-public-content
  margin-top 30px

.user-root-section
  margin-bottom 30px
  padding 20px
  border 1px solid $color_border
  border-radius 8px
  background-color $color_surface
  
  h2
    color $color_text
    font-size 1.25rem
    margin-bottom 16px
    font-weight 400
    
  p
    color $color_text_secondary
    line-height 1.6
    margin 0

.user-root-authenticated
  .user-root-header h1
    color $color_primary

.user-root-public
  .user-root-header h1
    color $color_text_secondary

@media (max-width: 768px)
  .user-root-container
    padding 20px 15px
    
  .user-root-header h1
    font-size 1.5rem
    
  .user-root-section
    padding 16px