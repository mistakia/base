.landing-container
  padding 30px 20px
  max-width 1000px
  margin 0 auto
  text-align center

.landing-header
  margin-bottom 40px
  
  h1
    color $color_text
    font-size 2.5rem
    margin-bottom 16px
    font-weight 300

.landing-description
  color $color_text_secondary
  font-size 1.1rem
  line-height 1.6
  max-width 600px
  margin 0 auto

.landing-actions
  margin-bottom 60px

.landing-action-primary
  display inline-block
  background-color $color_primary
  color white
  padding 12px 24px
  border-radius 6px
  text-decoration none
  font-weight 500
  font-size 1.1rem
  transition background-color 0.2s ease
  
  &:hover
    background-color $color_primary_hover
    text-decoration none

.landing-section
  margin-bottom 40px
  text-align left
  
  h2
    color $color_text
    font-size 1.5rem
    margin-bottom 20px
    font-weight 400

.landing-loading
  color $color_text_secondary
  font-style italic
  text-align center
  padding 20px

.landing-empty
  color $color_text_secondary
  text-align center
  padding 20px

.landing-users-grid
  display grid
  grid-template-columns repeat(auto-fill, minmax(280px, 1fr))
  gap 16px
  margin-bottom 20px

.landing-user-card
  display block
  padding 20px
  border 1px solid $color_border
  border-radius 8px
  background-color $color_surface
  text-decoration none
  transition all 0.2s ease
  
  &:hover
    background-color $color_surface_hover
    border-color $color_primary
    text-decoration none
    box-shadow 0 2px 8px rgba($primary_color_rgb, 0.1)

.landing-user-name
  color $color_text
  font-size 1.1rem
  font-weight 500
  margin-bottom 8px

.landing-user-info
  color $color_text_secondary
  font-size 0.9rem

.landing-footer
  margin-top 60px
  padding-top 20px
  border-top 1px solid $color_border
  text-align center
  
  p
    color $color_text_secondary
    margin 0
    
  a
    color $color_link
    text-decoration none
    
    &:hover
      text-decoration underline

@media (max-width: 768px)
  .landing-container
    padding 20px 15px
    
  .landing-header h1
    font-size 2rem
    
  .landing-description
    font-size 1rem
    
  .landing-users-grid
    grid-template-columns 1fr
    gap 12px