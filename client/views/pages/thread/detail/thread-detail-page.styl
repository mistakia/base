.back-button
  display inline-flex
  align-items center
  color $color_text
  text-decoration none
  font-size 14px
  margin-right 16px

  &:hover
    color $color_primary

  svg
    margin-right 8px

.chat-container
  flex 1
  overflow hidden

.error-state
  display flex
  flex-direction column
  align-items center
  justify-content center
  height 100%
  padding 24px
  color $color_danger
  text-align center 