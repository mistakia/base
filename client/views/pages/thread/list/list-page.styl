.page-container
  display flex
  flex-direction column
  height 100%
  overflow hidden

.header
  display flex
  align-items center
  justify-content space-between
  padding 16px
  border-bottom 1px solid $color_border
  background $color_header_background

.title
  font-size 18px
  font-weight 600
  margin 0

.create-button
  display inline-flex
  align-items center
  justify-content center
  padding 8px 16px
  border-radius 4px
  background $color_primary
  color white
  text-decoration none
  font-weight 500
  font-size 14px
  transition background 0.2s

  &:hover
    background $color_primary_hover

.list-container
  flex 1
  overflow auto 