.settings-page
  max-width 720px
  margin 0 auto
  padding 24px 16px

  h1
    font-size 24px
    margin-bottom 24px

  &__section
    margin-bottom 32px

    h2
      font-size 18px
      margin-bottom 16px
      padding-bottom 8px
      border-bottom 1px solid var(--border-color, #e0e0e0)

  &__row
    padding 8px 0

  &__label
    display flex
    align-items center
    gap 8px
    cursor pointer

    input[type='checkbox']
      width 16px
      height 16px
      cursor pointer

    span
      font-size 14px
