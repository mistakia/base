.page-container
  display flex
  flex-direction column
  height 100%
  overflow hidden

.header
  display flex
  align-items center
  justify-content space-between
  padding 16px
  border-bottom 1px solid $color_border
  background $color_header_background

.title
  font-size 18px
  font-weight 600
  margin 0

.list-container
  flex 1
  padding 20px
  overflow auto

.task-link
  display block
  text-decoration none
  color inherit
  margin-bottom 12px
  
  &:hover
    opacity 0.9

.no-tasks
  color $color_text_secondary
  text-align center
  padding 20px 