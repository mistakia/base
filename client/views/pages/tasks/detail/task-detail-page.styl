@import '../../../../styles/mixins'

.back-button
  display inline-flex
  align-items center
  color $color_text
  text-decoration none
  font-family $font_family_mono
  font-size $font_size_base
  margin-right $space_base

  &:hover
    color $color_primary

  svg
    margin-right $space_sm

.task-detail-container
  flex 1
  padding $space_lg
  overflow auto

.task-detail-header
  display flex
  align-items center
  margin-bottom $space_base
  
  .task-status, .task-priority
    status-badge()
    margin-right $space_base
  
  .task-status
    background-color $color_success_subtle
    color $color_success
  
  .task-priority
    background-color $color_warning_subtle
    color $color_warning

.task-description
  margin-bottom $space_lg
  font-family $font_family_mono
  font-size $font_size_base
  line-height 1.6
  color $color_text

.task-actions
  margin-top $space_base
  display flex
  gap $space_sm

.error-state
  display flex
  flex-direction column
  align-items center
  justify-content center
  height 100%
  padding $space_lg
  color $color_danger
  font-family $font_family_mono
  text-align center