$homepage_tasks_grid_template = 2fr 80px 80px 70px
$homepage_tasks_grid_template_mobile = 1fr

.homepage-right-column
  display grid
  grid-template-columns 1fr
  gap 16px
  width 100%

.threads-container
    padding 18px
    border 1px solid $color_border
    background rgba(0,0,0,0.02)
    border-radius 8px

.tasks-container
  &.loading-home-tasks
    text-align center
    padding 40px 18px
    color #666

.tasks-table
  width 100%
  overflow hidden

  .tasks-table-header
    display grid
    grid-template-columns $homepage_tasks_grid_template
    gap 16px
    padding 8px 20px
    border-bottom 1px solid #e9ecef
    font-weight 800
    color #495057
    font-size 11px
    text-transform uppercase
    letter-spacing 1px

    .task-header-with-link
      display flex
      align-items center
      gap 16px

      .view-all-link
        color $color_primary
        text-decoration none
        font-size $font_size_xs
        font-weight 400
        text-transform lowercase
        letter-spacing 0
        transition color $transition_base

        &:hover
          color $color_primary_hover
          text-decoration underline

  .tasks-table-body
    .task-row
      display grid
      grid-template-columns $homepage_tasks_grid_template
      gap 16px
      padding 8px 20px
      border-bottom 1px solid #f1f3f4
      align-items center
      transition background-color 0.2s ease

      &:hover
        background-color #f8f9fa

      &:last-child
        border-bottom none

      .task-title
        font-weight 500
        color #212529
        font-size 14px
        line-height 1.4

      .task-finish-by
        font-size 12px
        color #6c757d
        font-family monospace

  .tasks-toggle-container
    padding 12px 20px
    text-align center
    border-top 1px solid #f1f3f4

    .tasks-toggle-button
      background none
      border none
      color $color_text_secondary
      font-size 12px
      cursor pointer
      padding 4px 8px
      border-radius 4px
      transition all $transition_base

      &:hover
        color $color_text
        background-color #f8f9fa

.no-ongoing-tasks
  text-align center
  padding 40px 18px
  color #6c757d
  font-size 16px
  margin-bottom 20px

// Responsive design for smaller screens
@media (max-width 768px)
  .tasks-table
    .tasks-table-header,
    .tasks-table-body .task-row
      grid-template-columns $homepage_tasks_grid_template_mobile
      gap 8px
      padding 12px 16px

    .tasks-table-header
      display none

    .task-row
      .task-title
        font-size 16px
        font-weight 600
        margin-bottom 8px

      .task-status,
      .task-priority,
      .task-finish-by
        font-size 11px