$homepage_tasks_grid_template = 2fr 80px 80px 70px
$homepage_tasks_grid_template_mobile = 1fr

.home-file-browser
  width 100%
  border 1px solid darken($breadcrumb_light_color, 10%)
  border-radius 8px
  background $breadcrumb_light_color
  overflow hidden

  .home-file-browser-header
    display flex
    justify-content space-between
    align-items center
    padding 12px 18px
    cursor pointer
    user-select none
    transition background-color 0.2s
    border-radius 8px

    &:hover
      background-color darken($breadcrumb_light_color, 5%)

    &:focus
      outline none
      background-color darken($breadcrumb_light_color, 5%)

  // When expanded, header only has top border-radius
  &.home-file-browser--expanded
    .home-file-browser-header
      border-radius 8px 8px 0 0

  .home-file-browser-title
    font-weight 600
    font-size 14px
    color $breadcrumb_dark_color

  .home-file-browser-toggle
    font-size 12px
    color $breadcrumb_dark_color
    opacity 0.7
    transition opacity 0.2s

    &:hover
      opacity 1

  .home-file-browser-content
    border-top 1px solid darken($breadcrumb_light_color, 10%)
    padding 0
    background $color_surface
    border-radius 0 0 8px 8px

.homepage-right-column
  display grid
  grid-template-columns 1fr
  gap 16px
  width 100%
  max-width 100%
  min-width 0
  overflow hidden

.threads-container
    padding 18px
    border 1px solid $color_border
    background rgba(0,0,0,0.02)
    border-radius 8px
    width 100%
    max-width 100%
    min-width 0

.tasks-container
  width 100%
  max-width 100%
  min-width 0
  
  &.loading-home-tasks
    text-align center
    padding 40px 18px
    color $color_text_secondary

.tasks-table
  width 100%
  max-width 100%
  min-width 0
  overflow hidden

  .tasks-table-header
    display grid
    grid-template-columns $homepage_tasks_grid_template
    gap 16px
    padding 8px 20px
    min-width 0
    font-weight 800
    color $color_text_secondary
    font-size 11px
    text-transform uppercase
    letter-spacing 1px

    .task-header-with-link
      display flex
      align-items center
      gap 16px

      .view-all-link
        color $color_primary
        text-decoration none
        font-size $font_size_xs
        font-weight 400
        text-transform lowercase
        letter-spacing 0
        transition color $transition_base

        &:hover
          color $color_primary_hover
          text-decoration underline

  .tasks-table-body
    display flex
    flex-direction column
    gap 16px

    .task-group
      border-radius 8px
      overflow hidden
      border 1px solid $color_border_light

      &.task-group-even
        background-color $color_white

      &.task-group-odd
        background-color $color_surface_secondary

    .task-group-header
      display flex
      align-items center
      gap 6px
      padding 4px 20px
      background-color mix($breadcrumb_light_color, $color_white, 50%)
      border-bottom 1px solid darken($breadcrumb_light_color, 8%)

      .task-group-name
        font-weight 600
        font-size 10px
        color $color_text_secondary
        text-transform uppercase
        letter-spacing 0.5px

      .task-group-count
        font-size 10px
        color $color_text_tertiary
        font-weight 400

    .task-group-items
      .task-row:last-child
        border-bottom none

    .task-row
      display grid
      grid-template-columns $homepage_tasks_grid_template
      gap 16px
      padding 8px 20px
      min-width 0
      border-bottom 1px solid $color_border_light
      align-items center
      transition background-color 0.2s ease

      &:hover
        background-color $color_surface_secondary

      &:last-child
        border-bottom none

      .task-title
        font-weight 500
        color $color_text
        font-size 14px
        line-height 1.4

      .task-finish-by
        font-size 12px
        color $color_text_secondary
        font-family monospace

  .tasks-toggle-container
    padding 12px 20px
    text-align center
    border-top 1px solid $color_border_light

    .tasks-toggle-button
      background none
      border none
      color $color_text_secondary
      font-size 12px
      cursor pointer
      padding 4px 8px
      border-radius 4px
      transition all $transition_base

      &:hover
        color $color_text
        background-color $color_surface_secondary

.no-ongoing-tasks
  text-align center
  padding 40px 18px
  color $color_text_secondary
  font-size 16px
  margin-bottom 20px

// Responsive design for smaller screens
@media (max-width 768px)
  .tasks-table
    .tasks-table-header,
    .tasks-table-body .task-row
      grid-template-columns $homepage_tasks_grid_template_mobile
      gap 8px
      padding 12px 16px

    .tasks-table-header
      display none

    .task-row
      .task-title
        font-size 16px
        font-weight 600
        margin-bottom 8px

      .task-status,
      .task-priority,
      .task-finish-by
        font-size 11px