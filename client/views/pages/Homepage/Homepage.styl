$homepage_tasks_grid_template = 2fr 80px 80px 70px
$homepage_tasks_grid_template_mobile = 1fr

// Shared section header styles (used by tasks, files, etc.)
.home-section-header
  display flex
  align-items center
  gap $space_xs
  padding $space_xs 0
  font-size $font_size_xs
  font-weight $font_weight_semibold
  text-transform uppercase
  letter-spacing 0.5px
  color $color_text_secondary

  &--clickable
    cursor pointer
    user-select none
    border-radius $radius_sm
    margin 0 (-$space_xs)
    padding $space_xs

    &:hover
      background $color_surface_hover

    &:focus
      outline none
      background $color_surface_hover

.home-section-header__toggle
  display flex
  align-items center
  justify-content center
  width 16px
  height 16px
  padding 0
  color $color_text_tertiary
  font-size $font_size_xs
  font-family $font_family_mono
  flex-shrink 0

.home-section-header__dot
  width 8px
  height 8px
  border-radius 50%
  flex-shrink 0

  &--tasks
    background-color $color_primary

  &--files
    background-color $color_text_tertiary

  &--active
    background-color $color_success
    animation pulse 1.5s ease-in-out infinite

  &--review
    background-color $color_warning

.home-section-header__title
  flex 0 0 auto

.home-section-header__count
  font-family $font_family_mono
  font-size $font_size_xs
  color $color_text_tertiary
  background $color_surface_secondary
  padding 2px 6px
  border-radius $radius_sm
  text-decoration none
  transition all $transition_fast

  &:hover
    color $color_primary
    background $color_surface_hover
    text-decoration none

// Header variant with controls (toggle buttons) on the right
.home-section-header--with-controls
  justify-content space-between

.home-section-header__left
  display flex
  align-items center
  gap $space_xs

// Time period toggle button group (similar to nano-community style)
.time-period-toggle
  display flex
  flex-shrink 0
  border-radius $radius_sm
  border 1px solid $color_border_light
  border-radius $radius_sm
  background $color_white
  overflow hidden
  padding $space_sm

  &__button
    border none
    background transparent
    color $color_text_secondary
    font-size 10px
    font-family $font_family_mono
    font-weight $font_weight_medium
    border-radius $radius_sm
    padding 3px 8px
    cursor pointer
    transition all $transition_fast
    text-transform lowercase

    &:hover
      background $color_surface_hover
      color $color_text

    &--active
      background $color_primary
      color $color_white

      &:hover
        background darken($color_primary, 10%)
        color $color_white

    &:focus
      outline none

.home-file-browser
  width 100%

  .home-file-browser-content
    margin-top $space_sm
    border 1px solid $color_border_light
    border-radius $radius_base
    background $color_surface
    overflow hidden

.homepage-right-column
  display grid
  grid-template-columns 1fr
  gap $space_sm
  width 100%
  max-width 100%
  min-width 0

.tasks-container
  width 100%
  max-width 100%
  min-width 0

.tasks-table
  width 100%
  max-width 100%
  min-width 0
  overflow hidden
  margin-top $space_sm

  .tasks-table-header
    display grid
    grid-template-columns $homepage_tasks_grid_template
    gap 16px
    padding 8px 20px
    min-width 0
    font-weight 800
    color $color_text_secondary
    font-size 11px
    text-transform uppercase
    letter-spacing 1px

  .tasks-table-body
    display flex
    flex-direction column
    gap 16px

    .task-group
      border-radius 8px
      overflow hidden
      border 1px solid $color_border_light

    .task-group-header
      display flex
      align-items center
      gap 6px
      padding 4px 20px
      background-color mix($breadcrumb_light_color, $color_white, 50%)
      border-bottom 1px solid darken($breadcrumb_light_color, 8%)

      .task-group-name
        font-weight 600
        font-size 10px
        color $color_text_secondary
        text-transform uppercase
        letter-spacing 0.5px

      .task-group-count
        font-size 10px
        color $color_text_tertiary
        font-weight 400

    .task-group-items
      .task-row:last-child
        border-bottom none

    .task-row
      display grid
      grid-template-columns $homepage_tasks_grid_template
      gap 16px
      padding 8px 20px
      min-width 0
      border-bottom 1px solid $color_border_light
      align-items center
      transition background-color 0.2s ease

      &:hover
        background-color $color_surface_secondary

      &:last-child
        border-bottom none

      .task-title
        font-weight 500
        color $color_text
        font-size 14px
        line-height 1.4

      .task-finish-by
        font-size 12px
        color $color_text_secondary
        font-family monospace

// Responsive design for smaller screens
@media (max-width 768px)
  .tasks-table
    .tasks-table-header,
    .tasks-table-body .task-row
      grid-template-columns $homepage_tasks_grid_template_mobile
      gap 8px
      padding 12px 16px

    .tasks-table-header
      display none

    .task-row
      .task-title
        font-size 16px
        font-weight 600
        margin-bottom 8px

      .task-status,
      .task-priority,
      .task-finish-by
        font-size 11px