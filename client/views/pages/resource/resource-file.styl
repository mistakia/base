@import '../../../styles/mixins'

.resource-file
  width 100%
  min-height 100vh

.file-header
  margin-bottom $space_2xl
  padding-bottom $space_lg
  header-separator()

.breadcrumbs
  breadcrumb()
  margin-bottom $space_base
  
  .scheme
    color $color_text
    font-weight $font_weight_semibold
    letter-spacing 0.5px
    
  .breadcrumb-link
    color $color_text_secondary
    text-decoration none
    transition color $transition_base
    
    &:hover
      color $color_text
      
  .filename
    color $color_text
    font-weight $font_weight_medium

.entity-metadata
  background $color_surface
  border 1px solid $color_border
  margin-bottom $space_xl
  overflow hidden

.metadata-grid
  metadata-grid()

.metadata-item
  metadata-item()

.file-content
  background $color_surface
  border 1px solid $color_border
  overflow hidden
  
  .text-content
    padding $space_lg
    margin 0
    font-family $font_family_mono
    font-size $font_size_base
    line-height 1.6
    color $color_text
    background transparent
    border none
    white-space pre-wrap
    word-wrap break-word
    overflow-x auto

.no-content
  empty-state()

// Enhanced styling for markdown content
.file-content .markdown-content
  padding $space_xl
  
  h1, h2, h3, h4, h5, h6
    font-family $font_family_mono
    color $color_text
    margin-top $space_xl
    margin-bottom $space_base
    line-height 1.3
    
    &:first-child
      margin-top 0
      
  h1
    font-size $font_size_3xl
    font-weight $font_weight_bold
    border-bottom 2px solid $color_border
    padding-bottom $space_sm
    
  h2
    font-size $font_size_2xl
    font-weight $font_weight_semibold
    
  h3
    font-size $font_size_xl
    font-weight $font_weight_semibold
    
  h4, h5, h6
    font-size $font_size_lg
    font-weight $font_weight_semibold
  
  p
    font-family $font_family_mono
    font-size $font_size_base
    line-height 1.6
    color $color_text
    margin-bottom $space_base
    
  ul, ol
    margin-bottom $space_base
    padding-left $space_lg
    
  li
    font-family $font_family_mono
    font-size $font_size_base
    line-height 1.6
    color $color_text
    margin-bottom $space_xs
    
  code
    background rgba($color_border, 0.3)
    padding $space_xs $space_sm
    border-radius $radius_sm
    font-family $font_family_mono
    font-size $font_size_sm
    
  pre
    code-block()
    margin $space_base 0

// Enhanced JSON viewer styling
.file-content .json-viewer
  padding $space_lg
  font-family $font_family_mono
  font-size $font_size_sm
  line-height 1.5
  
  .json-key
    color $color_primary
    font-weight $font_weight_semibold
    
  .json-string
    color #d73a49
    
  .json-number
    color #005cc5
    
  .json-boolean
    color #e36209
    
  .json-null
    color #6f42c1

// Enhanced code viewer styling  
.file-content .code-viewer
  .code-block
    code-block()
    margin 0
    
  .line-numbers
    color $color_text_secondary
    user-select none
    margin-right $space_base
    border-right 1px solid $color_border
    padding-right $space_base

// Responsive adjustments
+mobile-only()
  .file-header
    margin-bottom $space_xl
    
  .breadcrumbs
    font-size $font_size_sm
    
  .entity-metadata
    margin-bottom $space_lg
    
  .metadata-grid
    gap 0
    
  .metadata-item
    padding $space_base
    
  .file-content
    .text-content,
    .markdown-content,
    .json-viewer,
    .code-viewer .code-block
      padding $space_base