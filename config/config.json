{
  "server_port": 8080,
  "production_url": "",
  "production_wss": "",
  "public_url": "",
  "github_access_token": "",
  "github": {
    "webhook_secret": "",
    "projects": {}
  },
  "cors_origins": [],
  "system_main_branch": "main",
  "user_main_branch": "main",
  "user_id": "",
  "user_public_key": "",
  "cloudflare": {
    "zone_id": "",
    "user_email": "",
    "token": ""
  },
  "jwt": {
    "secret": "",
    "algorithms": ["HS256"]
  },
  "claude_session_import_service": {
    "storage_server": {
      "host": "",
      "user": "",
      "remote_path": ""
    },
    "notifications": {
      "alert_on_errors": false
    },
    "processing": {
      "debounce_ms": 500,
      "max_retries": 3,
      "backoff_factor": 2
    }
  },
  "thread_integration": {
    "raw_data_storage": {
      "timestamp_format": "date",
      "skip_unchanged": true
    }
  },
  "threads": {
    "cli": {
      "command": "claude",
      "default_execution_mode": "container",
      "session_timeout_minutes": 60
    },
    "queue": {
      "redis_url": "redis://localhost:6379",
      "max_concurrent_jobs": 3,
      "retry_attempts": 3,
      "retry_delay_seconds": 30
    }
  },
  "active_sessions": {
    "session_ttl_seconds": 3600,
    "cleanup_interval_seconds": 60
  },
  "opencode": {
    "default_model": "",
    "timeout_ms": 120000,
    "max_retries": 2,
    "models": {
      "production": "",
      "high_quality": "",
      "fast": ""
    }
  },
  "file_watchers": {
    "file_subscriptions_enabled": true,
    "git_status_watcher_enabled": true,
    "repo_file_watcher_enabled": true,
    "thread_watcher_enabled": true,
    "subscription_watch_paths": null,
    "subscription_exclude_dirs": [
      "repository",
      "thread",
      ".git",
      "node_modules",
      "embedded-database-index",
      "import-history"
    ],
    "max_concurrent_git_status": 5
  },
  "embedded_database_index": {
    "enabled": true,
    "file_watcher_enabled": true
  },
  "transcription": {
    "service_url": ""
  },
  "extensions": {
    "discovery_paths": []
  },
  "machine_registry": {},
  "discord": {
    "user_api_token": "",
    "channels": {},
    "server_id": ""
  },
  "claude_accounts": {
    "enabled": false,
    "accounts": [],
    "usage_check_cache_seconds": 300,
    "utilization_threshold": 90
  },
  "cli_queue": {
    "tag_limits": {
      "default": { "max_concurrent": 10 }
    }
  },
  "job_tracker": {
    "enabled": false,
    "path": "",
    "ssh_host": "storage",
    "api_url": "",
    "api_key": "",
    "discord_webhook_url": "",
    "missed_check_interval_ms": 300000
  },
  "user_containers": {
    "enabled": false,
    "data_directory": "/tmp/user-containers",
    "default_timeout_ms": 1800000,
    "default_max_concurrent": 1,
    "resource_limits": {
      "memory": "2g",
      "cpus": "1.0"
    },
    "never_mount": ["config/", "identity/", "role/", "import-history/", ".git/"],
    "container_ready_timeout_ms": 60000,
    "default_deny_bash_patterns": ["curl *", "wget *", "nc *", "ssh *", "sudo *", "docker *", "rm -rf *"]
  }
}
