{
  "app": {
    "name": "Human-in-the-Loop Agent System",
    "version": "0.1.0"
  },
  "server": {
    "port": 3000,
    "host": "localhost"
  },
  "data": {
    "directory": "data",
    "subdirectories": {
      "activities": "activities",
      "knowledge": "knowledge",
      "logs": "logs",
      "temp": "temp",
      "uploads": "uploads"
    }
  },
  "logging": {
    "level": "info",
    "format": "json",
    "console": true,
    "file": true,
    "max_size": 10485760,
    "max_files": 5
  },
  "tasks": {
    "scheduler": {
      "enabled": true,
      "cleanup_interval": "0 0 * * *",
      "backup_interval": "0 0 * * *"
    }
  },
  "git": {
    "enabled": true,
    "auto_commit": true,
    "commit_interval": 3600000,
    "user": {
      "name": "HITL Agent",
      "email": "agent@example.com"
    }
  },
  "api": {
    "rate_limit": {
      "window_ms": 900000,
      "max_requests": 100
    },
    "timeout": 30000
  }
} 