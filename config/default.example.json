{
  "environment": "development",
  "system": {
    "name": "Human-in-the-Loop Agent System",
    "version": "0.1.0",
    "data_directory": "./data"
  },
  "vcs": {
    "git_directory": "./data/git",
    "auto_commit": true,
    "commit_message_template": "[{{agent_name}}] {{operation}} {{resource_type}}: {{title}}"
  },
  "data": {
    "storage_directory": "./data",
    "indexing": {
      "enabled": true,
      "refresh_interval": 300
    },
    "classification": {
      "default_sensitivity": "internal"
    }
  },
  "activities": {
    "definitions_directory": "./data/activities",
    "matcher": {
      "threshold": 0.7,
      "max_activities": 3
    }
  },
  "guidelines": {
    "definitions_directory": "./data/guidelines",
    "default_priority": "SHOULD"
  },
  "tasks": {
    "storage_directory": "./data/tasks",
    "default_priority": 3,
    "auto_assign": true
  },
  "human_interaction": {
    "notification": {
      "email": {
        "enabled": false,
        "smtp_server": "",
        "smtp_port": 587,
        "from_address": ""
      },
      "web": {
        "enabled": true
      }
    },
    "approval_workflow": {
      "default_timeout": 86400,
      "auto_approve_low_risk": false
    }
  },
  "access_control": {
    "audit_logging": true,
    "log_directory": "./data/logs",
    "default_permission": "propose-only"
  },
  "inference": {
    "storage_directory": "./data/inference",
    "parallel_processing": true,
    "result_storage": {
      "keep_all_results": true,
      "max_history": 100
    },
    "models": [
      {
        "model_id": "gpt-4",
        "name": "GPT-4",
        "provider": "openai",
        "api_key_env": "OPENAI_API_KEY",
        "capabilities": ["general", "code", "reasoning"],
        "cost_per_token": {
          "input": 0.00003,
          "output": 0.00006
        },
        "context_window": 8192,
        "preferred_activities": ["code_generation", "reasoning", "planning"]
      },
      {
        "model_id": "claude-3-opus",
        "name": "Claude 3 Opus",
        "provider": "anthropic",
        "api_key_env": "ANTHROPIC_API_KEY",
        "capabilities": ["general", "reasoning", "creative"],
        "cost_per_token": {
          "input": 0.00001,
          "output": 0.00003
        },
        "context_window": 100000,
        "preferred_activities": ["creative_writing", "summarization", "analysis"]
      }
    ]
  },
  "mcp": {
    "tools_directory": "./libs-server/mcp_handler/tools",
    "sampling": {
      "temperature": 0.7,
      "top_p": 0.9,
      "frequency_penalty": 0.0,
      "presence_penalty": 0.0
    }
  },
  "agents": {
    "registry_file": "./data/agents/registry.json",
    "scheduler": {
      "check_interval": 60
    },
    "default_agents": [
      {
        "agent_id": "task_manager",
        "name": "Task Manager",
        "description": "Manages and organizes tasks",
        "type": "task_agent",
        "supported_activities": ["task_creation", "task_organization", "task_assignment"],
        "triggers": [
          {
            "type": "schedule",
            "config": {
              "cron": "*/30 * * * *"
            }
          }
        ]
      },
      {
        "agent_id": "improvement_agent",
        "name": "Improvement Agent",
        "description": "Identifies and implements system improvements",
        "type": "improvement_agent",
        "supported_activities": ["self_improvement", "guideline_refinement", "prompt_optimization"],
        "triggers": [
          {
            "type": "schedule",
            "config": {
              "cron": "0 */6 * * *"
            }
          }
        ]
      }
    ]
  },
  "server": {
    "port": 3000,
    "host": "localhost",
    "cors": {
      "origin": "*",
      "methods": ["GET", "POST", "PUT", "DELETE"]
    }
  },
  "logging": {
    "level": "info",
    "file": "./data/logs/system.log",
    "max_size": 10485760,
    "max_files": 5
  }
} 