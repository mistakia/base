{
  "github": {
    "webhook_secret": "test_webhook_secret_for_testing"
  },
  "server_port": 8080,
  "server_host": "127.0.0.1",
  "production_url": "https://example.com",
  "production_wss": "wss://example.com",
  "base_hostname": "",
  "user_base_directory": "/tmp/base_data_test",
  "cloudflare": {
    "zone_id": "xxxxx",
    "user_email": "xxxxx",
    "token": "xxxxx"
  },
  "jwt": {
    "secret": "jwt_secret_test",
    "algorithms": ["HS256"]
  },
  "service_token": {
    "secret": "service_token_secret_test"
  },
  "threads": {
    "cli": {
      "command": "claude",
      "session_timeout_minutes": 60,
      "allow_custom_working_directory": true
    },
    "queue": {
      "redis_url": "redis://localhost:6379",
      "max_concurrent_jobs": 3,
      "max_jobs_per_user": 2,
      "retry_attempts": 3,
      "retry_delay_seconds": 30
    }
  },
  "embedded_database_index": {
    "enabled": true,
    "file_watcher_enabled": false
  },
  "machine_registry": {
    "test-host": {
      "hostname": "test-host",
      "platform": "darwin",
      "claude_paths": {
        "host_config_dir": {
          "test-primary": "~/.claude-test-primary/",
          "test-secondary": "~/.claude-test-secondary/"
        },
        "admin_data_dir": {
          "test-primary": "~/.base-container-data/claude-test-primary/",
          "test-secondary": "~/.base-container-data/claude-test-secondary/"
        }
      }
    },
    "test-host-default": {
      "hostname": "test-host-default",
      "platform": "darwin",
      "claude_paths": {
        "host_config_dir": {
          "test-primary": "~/.claude/"
        }
      }
    },
    "test-host-default-notrail": {
      "hostname": "test-host-default-notrail",
      "platform": "darwin",
      "claude_paths": {
        "host_config_dir": {
          "test-primary": "~/.claude"
        }
      }
    }
  },
  "claude_accounts": {
    "enabled": true,
    "accounts": [
      {
        "namespace": "test-primary",
        "priority": 1,
        "container_config_dir": "/home/node/.claude-test-primary/"
      },
      {
        "namespace": "test-secondary",
        "priority": 2,
        "container_config_dir": "/home/node/.claude-test-secondary/"
      }
    ]
  }
}
