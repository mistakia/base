{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "entry": [
    "client/index.js",
    "services/server.mjs",
    "services/mcp/mcp-server-sse.mjs",
    "services/mcp/mcp-server-stdio.mjs",
    "server/services/metadata-queue-processor.mjs",
    "server/services/cli-queue-worker.mjs",
    "server/services/relation-analysis-queue-processor.mjs",
    "cli/**/*.mjs",
    "webpack/*.mjs",
    "pm2.config.js",
    "tests/**/*.mjs"
  ],
  "project": [
    "client/**/*.{js,jsx}",
    "server/**/*.{js,mjs}",
    "libs-server/**/*.{js,mjs}",
    "libs-shared/**/*.{js,mjs}",
    "services/**/*.{js,mjs}",
    "config/**/*.{js,mjs}",
    "cli/**/*.{js,mjs}",
    "webpack/**/*.{js,mjs}",
    "tests/**/*.{js,mjs}"
  ],
  "ignore": ["build/**", "static/**", "tmp/**"],
  "ignoreDependencies": [
    "babel-loader",
    "css-loader",
    "style-loader",
    "stylus-loader",
    "html-loader",
    "compression-webpack-plugin",
    "circular-dependency-plugin"
  ]
}
